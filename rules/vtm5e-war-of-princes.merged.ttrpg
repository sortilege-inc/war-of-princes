            #eTB5P7U4wwbuc8kMLXeBkZ: lifting_capacity
            #AwVaQt7piwdggTgjNjXtSN: athletics_combinations
            #83QsELQwfm4EDbBf4fV7Jt: intimidation_displays
        }
    }
    ^"Dexterity" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 1 MAX 5
        # Agility, grace, and fine motor control. Used for precise movements,
        # ranged combat, stealth, and activities requiring coordination.
        RULES {

    ^"Broken Social Scene" DEF {
        APPLIES TO [^"Kindred"]
        # Event-based hunting opportunities where crowds and shared emotion
        # create ideal feeding conditions. Not location-dependent - can
        # happen across multiple districts.
        # 
        # High Intensity Resonance chance due to heightened emotions.
        EXAMPLES {
            "After-School Activity"
            MODIFIER "+1 Social/Mental hunting pools"
            "Alcoholics Anonymous"
            MODIFIER "-1 non-Physical hunting difficulty"
            "Art Installation"
            MODIFIER "+2 hunting difficulty without setup"
            "Convention"
            MODIFIER "-2 hunting difficulty, no over-hunting risk"
            "Illegal Outdoor Rave"
            MODIFIER "-3 hunting difficulty, drugs in blood"
            "Milonga/Dance Event"
            MODIFIER "Performance roll bonus dice to hunting"
            "Night Game"
            MODIFIER "-1 hunting difficulty, alcohol in blood"
            "Protest"
            MODIFIER "+2 police presence vs -2 crowd bonus"
            "Street Festival"
            MODIFIER "-2 hunting difficulty"
        }
        RULES {
            #n8Xzd2kejpX77ehDXSeEQW: event_based_opportunities
            #Z83BcA8B9ftjHcE3ZiZQBT: intensity_resonance_bonus
            #R2DkDKq2chEP92pS2Xf8br: crowd_concealment_advantages
            #RiXkVnB29sK6qSU3UkerUW: temporary_nature_challenges
        }
    }
    ^"Conflict Action Type" DEF {
        ENUM ["Advance", "Maneuver", "Block", "All-Out Attack", "All-Out Defense"]
        # Alternative conflict actions beyond direct attack, allowing for
        # more tactical and goal-oriented conflict resolution.
        RULES {
            #kfGmyhNEnLXf8XXHQhHCpg: advance_toward_goal
            #ZZQWERMocvf4UDBTSQfU5C: maneuver_advantage
            #ZduWBU9d232sXWcErhF3rf: block_opposition
            #3dLjDHbYtm7BUumWtdWYUD: all_out_attack_risk
            #Av5X78Rdsih9FvLPufZhqg: all_out_defense_bonus
        }
    }
    ^"Goal Roll" DEF {
        DICE_POOL "Variable (may differ from Launch roll)"
        OPPOSITION "Current Project Die value"
        # Forced advancement attempt against project timeline. Players roll
        # against dice pool equal to current Project Die value. Cannot spend
        # Willpower, Blood Surges, or usually Disciplines. No critical wins
        # for player, but opposition criticals count (house advantage).
    }
    ^"History" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        STRING
        # Character's life story including mortal existence, circumstances
        # of Embrace, and significant events in their vampire existence.
        RULES {
            #ZW3zDZnr5c5v9bHdHnYzFf: motivation_foundation
            #VzbBDDupPpxiipF4FCUjhL: relationship_establishment
            #CPj8HrGMZe74idaJb7U6GQ: story_integration
            #T9DPSgwrcnutxPU32gqcfP: roleplaying_guidance
        }
    }
    ^"International Travel Difficulty" DEF {
        APPLIES TO [^"Kindred"]
        INTEGER MIN 0 MAX 10
        # Border crossings and airports put vampires on surveillance lists.
        # Even successful passage creates electronic trail that
        # Second Inquisition can analyze and exploit.
        RULES {
            #aiNdTeZXpLfXsrvcysEBMU: border_crossing_detection
            #dfGpR22fFRvqsBomK4YkQd: airport_surveillance_risk
            #fyuW9UQAShFhVdefyQHkzh: electronic_trail_creation
            #iqh7iCTV88ikAEQUWrGqTb: analysis_exploitation_threat
        }
    }
    ^"Launch Roll" DEF {
        DICE_POOL "Skill + Background"
        DIFFICULTY "Project Scope + 2"
        # Initial roll to start a project after laying groundwork. Most projects
        # use relevant Skill + appropriate Background. Cannot spend Willpower
        # or use Blood Surge. Storyteller may allow Disciplines if targeting mortals.
        EXAMPLES {
            "Courting harpy"
            "Subterfuge + Status"
            "Destroying bank"
            "Finance + Resources"
            "Vice squad takeover"
            "Politics + Influence"
            "Occult research"
            "Occult + Loresheet or Blood Sorcery"
        }
    }
    ^"OK Check In" DEF {
        SAFETY_TOOL
        Status_Verification
        # Hand signal system for checking on other players during intense scenes.
        # Uses OK symbol for query and thumbs up/down/wiggle for responses.
        # Anything but thumbs up stops play.
        RULES {
            #3onbsPBAgbnEoy6M5958nL: signal_system_definition
            #oAXGiZB8t3k3r8DM923voo: response_meanings
            #kcpBzggcXqN9m3BHNeJ6PN: play_stopping_triggers
            #KwzJBa78orrDMjTvAHTRTf: breathing_space_provision
        }
    }
    ^"Required Dice" DEF {
        BOOLEAN DEFAULT true
        # Ten-sided dice in two colors required for play. Regular color for
        # normal dice, contrasting color (suggested red) for Hunger dice.
        # Special V5 dice available but standard d10s sufficient.
        RULES {
            #SY6yZAb3HKB2N7vVYax2ik: ten_sided_dice_requirement
            #F7rbMMQsXfp6y8KS2AeDtD: two_color_system_needed
            #bzprDFzWbKDu77kT2dfyAy: hunger_dice_visual_distinction
            #Sqc8SofJ9wz6RkvxsNHVXb: standard_d10_compatibility
        }
    }
    ^"Rouse Check" DEF {
        # Test made when activating most discipline powers. Failure increases
        # Hunger by one point. Uses a single d10 against Hunger difficulty.
        RULES {
            #LfqSRv2tmb4QBJsN2W4pSg: activation_triggers
            #4wEmLnvssyqk7dKzXMyM3t: hunger_increase_failure
            #97FanHKX9z3MxaoTVtS5z9: difficulty_scaling
        }
    }
    ^"Session Management" DEF {
        # Practical considerations for running consistent chronicle including
        # logistics coordination, player communication, and group maintenance.
        # Success depends on clear expectations and shared responsibilities.
        PROPERTIES {
            ^"Session Length" INTEGER DEFAULT 4
            HOURS
            ^"Frequency" ENUM ["Weekly", "Bi-weekly", "Monthly", "Irregular"]
            ^"Host Responsibilities" LIST OF STRING
            ^"Exit Policy" STRING
            ^"Communication Methods" LIST OF STRING
        }
        RULES {
            #MaRxGUJ3ngm9dnAMmPZVSZ: logistics_burden_sharing
            #aW324m79af2vJQi743CteT: player_exit_accommodation
            #FSTsjdcKCo5SWbiXbiFExb: conflict_resolution_protocol
        }
    }
    ^"Story Scale Flexibility" DEF {
        ENUM ["Spy Thriller", "Political Intrigue", "Human-Scale Drama", "Background Presence"]
        # World elements can be foreground spy story with Inquisition
        # agents and Camarilla secrets, or background context for
        # smaller personal stories.
        RULES {
            #F5NksvGN6sEGeMaJjh2SfC: spy_story_foreground_option
            #Bh455WzVUCydAi9F92KpVz: political_intrigue_focus
            #7SuoaWQxUEzWdXTzugHPrf: human_scale_alternative
            #SNnuq9oRqhjpvmTxocEoGk: background_context_use
            #TvoMAWagVAdUchjtZmgjGf: storyteller_scale_choice
        }
    }
    ^"Storyteller Role" DEF {
        BOOLEAN DEFAULT false
        # Single participant who creates setting, guides story, builds
        # supporting cast, and arbitrates rules. Primary duty is ensuring
        # other players have good time through balanced narration and adjudication.
        RULES {
            #d9PkbZB8cHo6Kfdsx79LBz: setting_creation_responsibility
            #DJHieoVpwvzok74KLP7iwf: supporting_character_control
            #UVy3bPJvMT9jBUZkiGkQYq: rule_arbitration_authority
            #oHaDg7hVF9FJMaFGCAimxw: story_guidance_balance
            #4Rg2L8AzikN5pP9FXnQsSj: player_entertainment_priority
        }
    }
    SPEC_VERSION "0.4"
    # Split from consolidated VTM5e_Core v0.1.4
    # Section: traits
    # Improvements in v0.1.7: Source file cleanup, "Bond Status" rename
    ^"Strength" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 1 MAX 5
        # Raw physical power and muscle mass. Used for lifting, breaking
        # objects, close combat damage, and athletic feats requiring brute force.
        RULES {

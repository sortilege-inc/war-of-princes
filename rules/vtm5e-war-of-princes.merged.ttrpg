    #I5jK7lM9nO1pQ3rS5tU7v ACTOR "NPC" DEF {
        EXTENDS #VnK8MrPxWbGhN2fQ4sT6uW ^"Entity"
        # Generic NPC - can be mortal, vampire, or other

    ^"Difficulty" DEF {
        INTEGER MIN 1 MAX 10
        # Number of successes required to accomplish an action.
        # Does not affect individual die target numbers.
        DIFFICULTY_SCALE {
            1 "Routine (striking stationary target, convincing loyal friend)"
            2 "Straightforward (seducing someone already in mood, intimidating weakling)"
            3 "Moderate (replacing car sound system, walking tightrope)"
            4 "Challenging (locating whisper source, creating memorable art)"
            5 "Hard (convincing cop cocaine isn't yours, rebuilding engine)"
            6 "Very Hard (running tightrope under fire, calming hostile mob)"
            7 "Nearly Impossible (finding specific homeless person in LA in one night)"
        }
        RULES {
            #josqqsH2E7Pa7CPgbRx5gS: storyteller_determination
            #kZ4GycNnnHhyT3ZSAh8g8x: equipment_modifiers
            #n35WRVDbnFMgLVxGTLbxxU: opposition_modeling

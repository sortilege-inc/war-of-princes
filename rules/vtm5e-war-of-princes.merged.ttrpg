            #M1nO3pQ5rS7tU9vW1xY3z: WHEN [^"Coterie" GAINS ^"Domain"] THEN ACCESS domain merits
        }
    }
    ^"Turn" DEF {
        # The amount of time needed to take a fairly simple action, such as

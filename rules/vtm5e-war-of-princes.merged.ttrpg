        }
    }
    ^"Disguised Weapons" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        TYPE
        Concealed_Armament EXAMPLES {
            ^"Sword Cane"
            VENTRUE_POPULAR ^"Caliber 22 Fountain Pen"
            DISCRETE ^"Pocket Watch Razor Spinner"
            INVENTIVE
        }
        CRAFTING {
            ^"Creation Roll"
            INTELLIGENCE_CRAFT_SPECIALTY ^"Detection Difficulty" "1"
            _PLUS_STEALTH_OR_CRAFT_WHICHEVER_HIGHER ^"Balance Penalty"
            MINUS_1_DIE_UNLESS_CRITICAL_WIN
        }
        # Increasingly popular in Camarilla domains as Second Inquisition
        # increases scrutiny through security searches. Cannot be properly
        # balanced unless masterfully crafted.
    }
    ^"Experience Points" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 999999
        # Points earned through play used to improve character abilities.
        # Awarded based on sessions and story completion.
        ADVANCEMENT_COSTS {
            ^"Attributes"
            COST "new rating × 5 XP"
            ^"Skills"
            COST "new rating × 3 XP"
            ^"Specialties"
            COST "3 XP each"
            ^"Willpower"
            COST "current rating × 8 XP"
            ^"Other Traits"
            COST "variable by type"
        }
        RULES {
            #3RaQRmZsDZ8b36bBFxpwnC: session_awards
            #SptrkuLHNLfgbR2NdTNppB: story_completion_bonus
            #iKsWzJ9fvjgKDKS74d7eJi: advancement_requirements
        }
    }
    ^"Explosives" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        DICE_POOLS ["Intelligence + Science", "Intelligence + Technology", "Intelligence + Craft", "Intelligence + Larceny"]
        # Creating, building, and using explosive devices for various purposes
        # from breaching walls to controlled demolitions. Highly dangerous
        # with severe consequences for failure.
        RULES {
            #NUC83d8BhrQKNYbHrY22pL: explosive_creation
            #ZewitQ9skzfstbHomznhja: bomb_construction
            #Jri8TbvRcpvV8sbj8LMKz8: targeted_demolition
            #PApJeZwAQMwvxc6r7MXreX: controlled_detonation
            #BaNVjzrAo4eRq5u2UqhqXf: catastrophic_failure_risks
        }
    }
    ^"Hunger Dice" DEF {
        INTEGER MIN 0 MAX 5
        # Red dice that replace normal dice equal to current Hunger.
        # Create risk of Messy Criticals and Bestial Failures,
        # representing the Beast's influence on actions.
        RULES {
            #JMTn4bW4pfrv9cedr7pP3R: normal_dice_replacement
            #YKxd3jAF7eWjWDoT5wR5Lj: messy_critical_risk
            #MHLYtTGd5cjXrJF3HooPnM: bestial_failure_possibility
            #2UzQJ4CorbCG4jCPs44Cno: beast_influence_representation
        }
    }
    ^"Remorse Test" DEF {
        DICE_POOL "unmarked Humanity dots"
        # End-of-session test to determine if vampire retains current Humanity
        # despite accumulated Stains. Roll dice equal to unfilled Humanity
        # spaces. Success removes all Stains, failure causes Humanity loss.
        RULES {
            #cvWCKYnQ63m9cqqYLSehBh: stain_removal_success
            #ZgaTyEUaRufmU6XX4LC3T5: humanity_loss_failure
            #Hj5FPFWKbTCDnKt69JbUcp: minimum_one_die
        }
    }
    ^"Resonance" DEF {
        APPLIES TO [^"Kindred"]
        STRING
        # Emotional resonance of consumed blood. Affects discipline power
        # intensity and vampire's emotional state. Changes based on prey type.
        RESONANCE_TYPES ["Anger", "Desire", "Fear", "Joy", "Melancholy", "Phlegmatic", "Sanguine", "Choleric"]
        RULES {
            #T2WMc6K9AvEFB5Py74zUFR: discipline_power_enhancement
            #YLAHSdfiE36LNAJATkPgFj: emotional_influence
            #Z7YG7rsB5tGqMNmKppmKMq: feeding_preference_development
        }
    }
    ^"Spent Experience" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0
        # Experience points already invested in character advancement.
        # Tracks character development and growth over time.
        RULES {
            #ZDjxoCxbg25eaCjzKdhfj4: advancement_tracking
            #5DsfEAnUnXjVPocwcEovJ6: development_history
            #jhG4d3gRvfdggQbhweBnBL: power_growth_record
        }
    }
    ^"Stains" DEF {
        APPLIES TO [^"Kindred", ^"Mortal"]
        INTEGER MIN 0 MAX 10
        # Marks of moral corruption on vampire's soul. Gained through violating
        # Chronicle Tenets or harming Touchstones. If stains exceed available
        # spaces on Humanity track, triggers degeneration and Willpower damage.
        RULES {
            #LNE4QzNrDqzpLx7M8gDb9b: tenet_violations
            #Rvre7biT2UYwoWqstWNvvr: touchstone_damage
            #Su5xXdLAewBZ6hfGdaenSb: degeneration_threshold
            #bmBPyK3tNGoUzUa8XsjX9J: conviction_mitigation
        }
    }
    ^"Starting Experience" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 35
        # Experience points granted based on character age category.
        # Represents learning and growth during vampire existence.
        EXPERIENCE_BY_AGE {
            "Childer"
            0 "Neonate"
            15 "Ancillae"
            35
        }
        RULES {
            #Ci84B4ExCboRH5EJoSi3Po: age_based_experience_grants
            #2GvwpLryDQb5h3RjfpCt3m: trait_advancement_spending
            #dTGYMsX8jEJ37nD3gnJbgU: discipline_learning_costs
        }
    }
    ^"Total Experience" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0
        # Cumulative experience points earned through play. Used to
        # advance character abilities and purchase new capabilities.
        RULES {
            #YqokdHj7VfMk9DpUcEzraZ: session_awards
            #LJdApiBRUqVrY7zT8KJiok: story_completion_bonuses
            #9U3zBrzu6ZBsKN2hxoYPDk: achievement_recognition
        }
    }
    SPEC_VERSION "0.4"
    # Official errata from Vampire: The Masquerade Companion
    # Incorporates all rule updates and clarifications from Part IV
    # These changes are optional and Storytellers may choose to ignore them
    # if the original rules work better for their table
    # ============================================================================
    # BLOOD POTENCY UPDATES
    # ============================================================================
    # Define Blood Surge value table (new content not in base)
    #YD4PosFYGnnbWia88WUziU "Blood Surge Table" DEF {
        # Increase Blood Surge value by one for all Blood Potency values
        # Taking the span from 0-5 to 1-6
        PROPERTIES {
            ^"Blood Potency 0" INTEGER 1
            ^"Blood Potency 1" INTEGER 2
            ^"Blood Potency 2" INTEGER 2
            ^"Blood Potency 3" INTEGER 3
            ^"Blood Potency 4" INTEGER 3
            ^"Blood Potency 5" INTEGER 4
            ^"Blood Potency 6" INTEGER 4
            ^"Blood Potency 7" INTEGER 5
            ^"Blood Potency 8" INTEGER 5
            ^"Blood Potency 9" INTEGER 6
            ^"Blood Potency 10" INTEGER 6
        }
        RULES {
            #iP6C6hYBkxMFk9Cdz8TstM: WHEN [^"Blood Potency" == 0] THEN ^"Blood Surge" GRANTS 1 die instead of 0
            #nBxFeUHZQMg9LjHe9DTcwU: WHEN [^"Thin-blood Character"] THEN GAINS ^"Blood Surge" ability with 1 die
            #gchPXU4nYZsKw6gP6WeBym: WHEN [^"Blood Surge" USED] THEN REQUIRES ^"Rouse Check" as normal
            #9SWbpbHZ6HzeqN734Cq4YS: WHEN [^"Blood Potency" 1-2] THEN ^"Blood Surge" MORE VIABLE for regular use
        }
    }
    # Define Bane Severity value table (new content not in base)
    #j3R4UBSHhb2PCJRiA2QrBQ "Bane Severity Table" DEF {
        # Increase Bane Severity value by one for all Blood Potency values
        # Taking the span from 0-5 to 1-6
        PROPERTIES {
            ^"Blood Potency 0" INTEGER 1
            ^"Blood Potency 1" INTEGER 2
            ^"Blood Potency 2" INTEGER 2
            ^"Blood Potency 3" INTEGER 3
            ^"Blood Potency 4" INTEGER 3
            ^"Blood Potency 5" INTEGER 4
            ^"Blood Potency 6" INTEGER 4
            ^"Blood Potency 7" INTEGER 5
            ^"Blood Potency 8" INTEGER 5
            ^"Blood Potency 9" INTEGER 6
            ^"Blood Potency 10" INTEGER 6
        }
        RULES {
            #AxxoYPPtNVYBZC4TCcXnHe: WHEN [^"Blood Potency" == 0] THEN ^"Bane Severity" EQUALS 1 instead of 0
            #he8Sj5DYDo94NsrTYoNLyq: WHEN [^"Thin-blood Character"] THEN GAINS ^"Bane Severity" BUT usually ignores unless ^"Clan Curse Flaw"
            #Qf7tJLjqGb2MowpwGExAzA: WHEN [^"Bane Severity" INCREASED] THEN ^"Clan Banes" BECOME more keenly felt curses
            #f5knf6j3wWa7U9azg7xEgN: WHEN [^"Low Blood Potency"] THEN ^"Banes" NO LONGER mere nuisances
        }
    }
    # Modify Blood Potency to reference the updated tables
    # Updated consolidated Blood Potency Table (new comprehensive reference)
    #GAPChu85x3G4pQ8synLh2J "Blood Potency Table" DEF {
        PROPERTIES {
            ^"Blood Potency 0" DEF {
                ^"Blood Surge" INTEGER 1
                ^"Damage Mended Per Rouse Check" STRING "1 point Superficial"
                ^"Discipline Power Bonus" STRING "None"
                ^"Discipline Rouse Check Re-roll" STRING "None"
                ^"Bane Severity" INTEGER 1
                ^"Feeding Penalty" STRING "No effect"
            }
            ^"Blood Potency 1" DEF {
                ^"Blood Surge" INTEGER 2
                ^"Damage Mended Per Rouse Check" STRING "1 point Superficial"
                ^"Discipline Power Bonus" STRING "None"
                ^"Discipline Rouse Check Re-roll" STRING "Level 1"
                ^"Bane Severity" INTEGER 2
                ^"Feeding Penalty" STRING "No effect"
            }
            ^"Blood Potency 2" DEF {
                ^"Blood Surge" INTEGER 2
                ^"Damage Mended Per Rouse Check" STRING "2 points Superficial"
                ^"Discipline Power Bonus" STRING "Add 1 die"
                ^"Discipline Rouse Check Re-roll" STRING "Level 1"
                ^"Bane Severity" INTEGER 2
                ^"Feeding Penalty" STRING "Animal and bagged blood slakes half Hunger"
            }
            ^"Blood Potency 3" DEF {
                ^"Blood Surge" INTEGER 3
                ^"Damage Mended Per Rouse Check" STRING "2 points Superficial"
                ^"Discipline Power Bonus" STRING "Add 1 die"
                ^"Discipline Rouse Check Re-roll" STRING "Level 2 and below"
                ^"Bane Severity" INTEGER 3
                ^"Feeding Penalty" STRING "Animal and bagged blood slakes no Hunger"
            }
            ^"Blood Potency 4" DEF {
                ^"Blood Surge" INTEGER 3
                ^"Damage Mended Per Rouse Check" STRING "3 points Superficial"
                ^"Discipline Power Bonus" STRING "Add 2 dice"
                ^"Discipline Rouse Check Re-roll" STRING "Level 2 and below"
                ^"Bane Severity" INTEGER 3
                ^"Feeding Penalty" STRING "Animal and bagged blood slakes no Hunger; Slake 1 less Hunger per human"
            }
            ^"Blood Potency 5" DEF {
                ^"Blood Surge" INTEGER 4
                ^"Damage Mended Per Rouse Check" STRING "3 points Superficial"
                ^"Discipline Power Bonus" STRING "Add 2 dice"
                ^"Discipline Rouse Check Re-roll" STRING "Level 3 and below"
                ^"Bane Severity" INTEGER 4
                ^"Feeding Penalty" STRING "Animal and bagged blood slakes no Hunger; Slake 1 less Hunger per human; Must drain and kill a human to reduce Hunger below 2"
            }
            ^"Blood Potency 6" DEF {
                ^"Blood Surge" INTEGER 4
                ^"Damage Mended Per Rouse Check" STRING "3 points Superficial"
                ^"Discipline Power Bonus" STRING "Add 3 dice"
                ^"Discipline Rouse Check Re-roll" STRING "Level 3 and below"
                ^"Bane Severity" INTEGER 4
                ^"Feeding Penalty" STRING "Animal and bagged blood slakes no Hunger; Slake 2 less Hunger per human; Must drain and kill a human to reduce Hunger below 2"
            }
            ^"Blood Potency 7" DEF {
                ^"Blood Surge" INTEGER 5
                ^"Damage Mended Per Rouse Check" STRING "3 points Superficial"
                ^"Discipline Power Bonus" STRING "Add 3 dice"
                ^"Discipline Rouse Check Re-roll" STRING "Level 4 and below"
                ^"Bane Severity" INTEGER 5
                ^"Feeding Penalty" STRING "Slake 2 less Hunger per human; Must drain and kill a human to reduce Hunger below 2"
            }
            ^"Blood Potency 8" DEF {
                ^"Blood Surge" INTEGER 5
                ^"Damage Mended Per Rouse Check" STRING "4 points Superficial"
                ^"Discipline Power Bonus" STRING "Add 4 dice"
                ^"Discipline Rouse Check Re-roll" STRING "Level 4 and below"
                ^"Bane Severity" INTEGER 5
                ^"Feeding Penalty" STRING "Animal and bagged blood slakes no Hunger; Slake 2 less Hunger per human; Must drain and kill a human to reduce Hunger below 3"
            }
            ^"Blood Potency 9" DEF {
                ^"Blood Surge" INTEGER 6
                ^"Damage Mended Per Rouse Check" STRING "4 points Superficial"
                ^"Discipline Power Bonus" STRING "Add 4 dice"
                ^"Discipline Rouse Check Re-roll" STRING "Level 5 and below"
                ^"Bane Severity" INTEGER 6
                ^"Feeding Penalty" STRING "Slake 2 less Hunger per human; Must drain and kill a human to reduce Hunger below 3"
            }
            ^"Blood Potency 10" DEF {
                ^"Blood Surge" INTEGER 6
                ^"Damage Mended Per Rouse Check" STRING "5 points Superficial"
                ^"Discipline Power Bonus" STRING "Add 5 dice"
                ^"Discipline Rouse Check Re-roll" STRING "Level 5 and below"
                ^"Bane Severity" INTEGER 6
                ^"Feeding Penalty" STRING "Animal and bagged blood slakes no Hunger; Slake 3 less Hunger per human; Must drain and kill a human to reduce Hunger below 3"
            }
        }
        RULES {
            #NM4cHSkzFK74uKfJs2gyfx: WHEN [REFERENCING ^"Blood Potency" VALUES] THEN USE this consolidated table
            #LbcvrFUiTtZhDEvUk9Srv5: WHEN [^"Blood Potency" INCREASES] THEN ALL associated values UPDATE per table
            #VYL4BDdTnkzbteetSiYrj2: WHEN [^"Character Creation"] THEN START with updated values from beginning
        }
    }
    # ============================================================================
    # MESSY CRITICAL UPDATES
    # ============================================================================
    # Define Messy Critical as a proper mechanic (referenced but not defined in base)
    #Ge42RxKEejJFxJAfHqBx5n "Messy Critical" DEF {
        # Messy Criticals can now trigger Compulsions just like Bestial Failures
        # Previously only complicated situations; now can also trigger Beast
        PROPERTIES {
            ^"Compulsion Trigger" BOOLEAN
            true  # Can trigger Compulsions
            ^"Success Type" STRING "Critical"
            ^"Complication" BOOLEAN
            true
        }
        RULES {
            #hhrsS5v7fs3QH5yTNLimma: WHEN [^"Messy Critical" OCCURS] THEN MAY trigger ^"Compulsion" like ^"Bestial Failure"
            #A8HT8vgqAeQMZYAEozYSjn: WHEN [^"Messy Critical" ON ^"Awareness Test"] THEN ^"Compulsion" HELPS explain tricky messes
            #4W9hbKzyF7G37X53Ev6gcs: WHEN [^"Messy Critical" ON ^"Passive Action"] THEN ^"Compulsion" PROVIDES narrative explanation
            #YwemU73mCKLU7MNkoJXxdM: WHEN [CHOOSING ^"Complication"] THEN COMBINE options from ^"Messy Critical" AND ^"Bestial Failure" lists
            #gkbDtfQ7TiN4HnGtzPAvvF: WHEN [^"Compulsions" FROM ^"Messy Criticals"] THEN MAKES them more frequent in play
        }
    }
    # Modify the existing dice rule that references Messy Criticals
    # Modify the existing hunger rule that triggers Messy Criticals
    # Define Compulsion Triggers (new content not in base)
    #ie7UarTNrzbEnJA8WpTozn "Compulsion Triggers" DEF {
        # Expand the triggers to include Messy Criticals
        PROPERTIES {
            ^"Bestial Failure Trigger" BOOLEAN
            true
            ^"Messy Critical Trigger" BOOLEAN
            true  # NEW
        }
        RULES {
            #RMUHt8mRSphHqbzcUhHmti: WHEN [#Ge42RxKEejJFxJAfHqBx5n ^"Messy Critical" OR ^"Bestial Failure"] THEN MAY trigger ^"Compulsion"
            #DvSDerLphzKKnDUF82d8Ns: WHEN [^"Storyteller" CHOOSES compulsion] THEN USE combined smörgåsbord of complications
            #FsnSzXiW8MiQTt9iAQ6SsR: WHEN [^"Compulsion" TRIGGERED] THEN CONSIDER both mechanical AND narrative context
        }
    }
    # ============================================================================
    # TAKING HALF MECHANICS
    # ============================================================================
    #TuWhXEfaJMCjJrhzvVF8iA "Taking Half" DEF {
        # Players can choose to "Take Half" instead of rolling dice
        # Count half the dice pool as regular successes
        PROPERTIES {
            ^"Available To" STRING "Players"
            ^"Calculation" STRING "Half dice pool rounded down as successes"
            ^"Prevents" LIST OF STRING ["Hunger complications", "Bestial Failures", "Messy Criticals"]
            ^"Storyteller Knowledge" STRING "Keep exact difficulties secret"
            ^"Storyteller Hints" LIST OF STRING ["This seems really beneath you", "You're not sure you can crack this without serious effort"]
        }
        RULES {
            #KXEG3YSG7WDyd22k5jZP6X: WHEN [^"Player" WANTS to ensure win on easy test] THEN MAY choose ^"Taking Half"
            #mmkwpST75jZBCNMrqYPqWH: WHEN [^"Player" WANTS to avoid ^"Hunger" complications] THEN MAY choose ^"Taking Half"
            #cZqq89ah4MUc4uupzgaVFS: WHEN [USING ^"Taking Half"] THEN COUNT half dice pool AS regular successes
            #jeG7cH8pfMq6NTfGFc5Rqu: WHEN [^"Storyteller" SETS difficulty] THEN KEEP exact number secret
            #EyF5mSz9CjiYZ2zS5Qn44D: WHEN [^"Test Difficulty" OBVIOUS] THEN ^"Storyteller" MAY provide descriptive hints
            #48EjCDi2G79DLFne2AMd4A: WHEN [^"Taking Half" CHOSEN] THEN NO ^"Hunger Dice", NO ^"Bestial Failures", NO #Ge42RxKEejJFxJAfHqBx5n ^"Messy Criticals"
            #R847n3Fd9iYwAvLCvhiRJ4: WHEN [^"Taking Half" SPEEDS up gameplay] THEN GIVES more player control over ^"Hunger" effects
        }
    }
    # ============================================================================
    # LINGERING KISS POWER DEFINITION
    # ============================================================================
    # Extend Lingering Kiss discipline power with detailed mechanics
    ^"[Presence]Lingering Kiss"
    EXTEND {
        # Complete definition of Lingering Kiss power to reduce exploitation
        # while keeping the concept of tempting players, not just characters
        PROPERTIES {
            ^"Cost" STRING "Free"
            ^"Duration" STRING "A number of nights equal to user's Presence rating"
            ^"Victim Bonus" STRING "Half user's Presence (round up) to one Social Attribute"
            ^"Bonus Duration" STRING "Single night"
            ^"Withdrawal Penalty" STRING "Dice penalty equal to initial bonus"
            ^"Withdrawal Duration" STRING "Number of nights equal to user's Presence rating"
            ^"Willpower Escape" BOOLEAN
            true
            ^"Blood Bond Restriction" BOOLEAN
            true
            ^"Unbondable Restriction" BOOLEAN
            true
        }
        DESCRIPTION "The Kiss of a vampire induces near-ecstasy in the victim, but this power leaves other Kisses in the dust. Victims fed upon by the user are temporarily empowered, but also become addicted to the Kiss, obsessing over it and even seeking the vampire out for repeated feedings. Mortals often become anemic, self-harm, or even die from this addiction. Addicting other vampires is also possible, with the caveat that obsessed vampires demanding to be fed from risk the user becoming Blood Bound. Once under a Blood Bond, a vampire becomes unable to use this power on other vampires, being limited to employing it on mortals."
        SYSTEM "The vampire can choose to use this power during each feeding where they sate at least one Hunger. The victim gains a bonus equal to half the user's Presence (round up) to one Social Attribute of their choice. This benefit lasts for a single night. Once it fades, withdrawal strikes and all the victim's actions not spent working toward acquiring a new fix receive a dice penalty equal to the initial bonus. A victim in withdrawal can spend Willpower to ignore the penalties for a scene, and the penalties go away after a number of nights equal to the user's Presence rating. This power cannot be used on other vampires by a user who is under the thrall of a Blood Bond. Also, vampires with the Unbondable Merit cannot acquire this power."
        RULES {
            #Ty2Ua2GQDCmpSsCjQ7puge: WHEN [USING ^"[Presence]Lingering Kiss" DURING feeding] THEN MUST sate at least 1 ^"Hunger"
            #GGjx7n2FvaQnqrHTEZ2P9S: WHEN [^"Victim" AFFECTED] THEN GAINS bonus equal to half ^"User Presence" rounded up
            #TLxNdFuq93G4Ut8NobDkQS: WHEN [^"Social Attribute" BONUS] THEN LASTS for single night only
            #ejtduqp79rEQdk7oG65Wxg: WHEN [^"Bonus" FADES] THEN ^"Withdrawal" STRIKES with dice penalty
            #NpoJ3V4832ipXitfJL4XLk: WHEN [IN ^"Withdrawal"] THEN ALL actions not seeking new fix RECEIVE penalty
            #8qAYTz73MU54e8Zzit3dpH: WHEN [^"Victim" SPENDS ^"Willpower"] THEN IGNORES penalties for one scene
            #M4uhoPHkXPeSu58eRSNxad: WHEN [^"Withdrawal" DURATION] THEN EQUALS user's ^"Presence" rating in nights
            #m9jseNT4Vkh5pumAmYFggg: WHEN [^"User" UNDER ^"Blood Bond"] THEN CANNOT use on other vampires
            #8J4m64QceUYp7yHRiZGYde: WHEN [^"User" HAS ^"Unbondable Merit"] THEN CANNOT acquire this power
            #8hNgbZCg4DBYg7A5KLvN8k: WHEN [^"Obsessed Vampires" DEMAND feeding] THEN RISK user becoming ^"Blood Bound"
            #3FiqrGq9a4pvNU6VwFenVE: WHEN [^"Mortals" BECOME addicted] THEN RISK anemia, self-harm, death
        }
    }
    # ============================================================================
    # AUTOMATIC WINS AND TEST RESOLUTION UPDATES
    # ============================================================================
    #einxE7pWFMBooF4L5Q4Rmf "Automatic Wins" DEF {
        # Clarification on when Storytellers should hand out automatic wins
        RULES {
            #kNrargDM6JyssX4PtABTua: WHEN [^"Test" CLEARLY beneath character capability] THEN ^"Storyteller" SHOULD grant ^"Automatic Win"
            #2KwgLu3RiqGsueBUCtJWYW: WHEN [^"Automatic Win" GRANTED] THEN NO dice rolling required
            #bgFbsFfwJzgYz7RTW7iwom: WHEN [#TuWhXEfaJMCjJrhzvVF8iA ^"Taking Half" AVAILABLE] THEN PROVIDES alternative to ^"Automatic Win"
        }
    }
    #6RpRGmJ7zR7zBvPdtZLcs9 "Secret Difficulties" DEF {
        # Storytellers should keep exact difficulties secret but provide hints
        PROPERTIES {
            ^"Exact Numbers" BOOLEAN
            false  # Keep secret
            ^"Descriptive Hints" BOOLEAN
            true  # Provide these
            ^"Player Choice" STRING "When to roll vs Take Half"
        }
        RULES {
            #JVTF7E32vVACnPDJa2MUQi: WHEN [SETTING ^"Test Difficulty"] THEN KEEP exact number secret from players
            #haafwyQmuveYA77WiTaxFm: WHEN [^"Players" NEED guidance] THEN PROVIDE descriptive hints about difficulty
            #gJWt9QnKAHew22FfeaxBS4: WHEN [^"Difficulty" VERY low] THEN MAY hint "this seems really beneath you"
            #WDYRnyqA8pFMo4XBaTzPyP: WHEN [^"Difficulty" VERY high] THEN MAY hint "you're not sure you can crack this without serious effort"
            #7Ei5kazvbvyDTaTXeQnVhe: WHEN [^"Players" CHOOSE roll vs #TuWhXEfaJMCjJrhzvVF8iA ^"Taking Half"] THEN GIVES more control over ^"Hunger" risk
        }
    }
    # ============================================================================
    # DESIGN PHILOSOPHY AND IMPLEMENTATION RULES
    # ============================================================================
    #Zx7aVSJuUoXc48pChazqBP "Errata Philosophy" DEF {
        # These changes address features that over- or under-performed in extended play
        # and clarify things that could have been more clearly defined
        PROPERTIES {
            ^"Optional Implementation" BOOLEAN
            true
            ^"Table Authority" STRING "Storytellers and players know their table best"
            ^"Change Reason" STRING "Extended play feedback and clarification needs"
        }
        RULES {
            #4rMfUVxCYv8vyr9fUAMSUj: WHEN [USING ^"Errata"] THEN IMPLEMENTATION is optional for each table
            #VefXBvT4eRBMzXwRTar9Sr: WHEN [^"Old Ways" WORKED for troupe] THEN ^"Storytellers" NOT required to adopt changes
            #Kk6suFaVdSsQRoU22z9du9: WHEN [^"Extended Play" REVEALS issues] THEN ^"Updates" ADDRESS over- and under-performance
            #L7FmW4E3K7SiKCSkiUEeGY: WHEN [^"Rules Clarity" NEEDED] THEN ^"Errata" PROVIDES better definitions
        }
    }
    # ============================================================================
    # VERSION CONTROL AND COMPATIBILITY
    # ============================================================================
    #3CeSuGrx7aa6reDfKhA5cW "Errata Version Control" DEF {
        PROPERTIES {
            ^"Core Book Compatibility" STRING "All versions"
            ^"Future Printings" BOOLEAN
            true
            ^"Official Errata Document" BOOLEAN
            true
            ^"Implementation Date" STRING "Optional by table"
        }
        RULES {
            #hPYQbmzU5pgw6nUhEoZ8ar: WHEN [^"Future Printings" OF core book] THEN WILL include these changes
            #dWQj9EcNdNkjG32qVVNC3r: WHEN [^"Latest Errata Document" AVAILABLE] THEN CONTAINS ^"[Presence]Lingering Kiss" update
            #dL4A22LCRAKKThPzQr3CME: WHEN [^"Table" ADOPTS errata] THEN SHOULD use consistently throughout chronicle
            #cFiLJmBQcTcqxc7SfMgDbw: WHEN [^"Mixed Implementation"] THEN ENSURE all players understand which rules in use
        }
    }
    SPEC_VERSION "0.4"
    # Campaign homebrew for the War of Princes chronicle (London, 1242). A Cainite
    # follows a ROAD rather than clinging to Humanity. The Road rating behaves like
    # the V5 Humanity track (0..10) — higher ratings give more dice to resist Frenzy,
    # low ratings impose penalties reflecting the Beast's influence, and the rating
    # falls through Degeneration. This file replaces ^"Humanity" for these characters.
    # ---- the Road morality track (the type each specific Road extends) ----
    #wopRoadTrack000001 ^"Road" DEF {
        APPLIES TO [^"Kindred"]
        INTEGER MIN 0 MAX 10
        DESCRIPTION "The Dark Ages morality track, used in place of Humanity for this chronicle. A character records which Road they walk and their current Road rating (starting at 7). Each Road has a hierarchy of sins; the rating sets which level of sin the character recognizes (that rating and every sin below it). Higher ratings are stricter and harder to hold; lower ratings are more permissive and require more severe sins to fall further."
        DERIVED_PROPERTIES {
            ^"Road Name"
            STRING
            ^"Aura"
            STRING
        }
        RULES {
            #wopRoadRuleFrenzy1: higher_road_rating_grants_more_dice_to_resist_frenzy
            #wopRoadRuleDegen01: committing_a_recognized_sin_causes_stains
            #wopRoadRuleRemors1: unresolved_stains_force_a_remorse_roll_at_end_of_session
            #wopRoadRuleFall001: failing_the_remorse_roll_lowers_the_road_rating_by_one
            #wopRoadRuleRaise01: raising_the_road_rating_requires_great_commitment_or_sudden_growth
            #wopRoadRulePenal01: low_ratings_impose_escalating_social_interaction_penalties
            #wopRoadRuleAura001: aura_is_projected_with_a_rouse_check_and_lasts_one_scene
        }
    }
    # ---- shared Road concepts ----
    #wopRoadDegen000001 ^"Road Degeneration" DEF {
        DESCRIPTION "Committing a sin the character recognizes (at or below their current Road rating) causes Stains. Unresolved Stains require a Remorse roll at the end of a session to resolve; failing the Remorse roll decreases the Road rating by one. Raising a Road rating requires a great commitment of time and effort, or rare moments of profound sudden growth."
    }
    #wopRoadAura0000001 ^"Road Aura" DEF {
        DESCRIPTION "An Aura is the feeling or impression a Cainite projects associated with their Road, making them appear more in line with their Road than their Beast and often disguising their vampiric nature. A character projects their Aura with a Rouse check; it lasts one scene. The mechanical effect differs by Road (see each Road's hierarchy). At high ratings some Auras become permanent."
        PROPERTIES {
            ^"Beast Aura" STRING "Predator's Instinct"
            ^"Humanity Aura" STRING "Blush of Life"
            ^"Heaven Aura" STRING "Holy Radiance"
            ^"Kings Aura" STRING "Air of Authority"
        }
    }
    # ============================================================
    # Road of the Beast (Ferals) — Via Bestiae
    # ============================================================
    #wopRoadBeast000001 ^"Road of the Beast" DEF {
        EXTENDS ^"Road"
        PROPERTIES {
            ^"Latin Name" STRING "Via Bestiae"
            ^"Followers" STRING "Ferals"
            ^"Aura" STRING "Predator's Instinct"
            ^"Tenets" LIST OF STRING [
                "Exist in accord with the needs of the Beast",
                "Do what you must to survive. No more, no less.",
                "Mercy is for the weak. Only the strong survive.",
                "The past is dead, the future is unborn. The moment is yours.",
                "Respect only the strong"
            ]
            ^"Hierarchy of Sins" DEF {
                ^"Rating 10" DEF {
                    ^"Moral Guideline" STRING "Taking foolhardy risks"
                    ^"Rationale" STRING "Survival is paramount"
                    ^"Effects" LIST OF STRING ["Permanently have the effects of Aura; appear as a living creature to beasts", "Heal Superficial damage as a mortal", "You can taste, eat, and digest food that you hunt", "Healing Aggravated damage during day sleep requires one Rouse check"]
                }
                ^"Rating 9" DEF {
                    ^"Moral Guideline" STRING "Leaving the weak unchallenged"
                    ^"Rationale" STRING "Only the strongest should lead"
                    ^"Effects" LIST OF STRING ["Permanently have the effects of Aura; appear as an ill creature", "Heal Superficial damage as a mortal", "Healing Aggravated damage during day sleep requires two Rouse checks"]
                }
                ^"Rating 8" DEF {
                    ^"Moral Guideline" STRING "Killing without need"
                    ^"Rationale" STRING "Murder is a creation of society"
                    ^"Effects" LIST OF STRING ["Roll two dice for the Aura Rouse check and take the highest result"]
                }
                ^"Rating 7" DEF {
                    ^"Moral Guideline" STRING "Avoiding the wilds"
                    ^"Rationale" STRING "In nature lies strength; civilization is soft and weak"
                    ^"Effects" LIST OF STRING ["Using Aura negates penalties from drinking animal blood", "With no penalties from animal blood, you can sate one additional Hunger than usual from an animal regardless of size"]
                }
                ^"Rating 6" DEF {
                    ^"Moral Guideline" STRING "Tormenting others needlessly"
                    ^"Rationale" STRING "Only civilized folk engage in these things"
                    ^"Effects" LIST OF STRING ["With Aura, penalties from drinking animal blood are treated as one Blood Potency level lower"]
                }
                ^"Rating 5" DEF {
                    ^"Moral Guideline" STRING "Making unbidden sacrifice"
                    ^"Rationale" STRING "You owe others nothing"
                    ^"Effects" LIST OF STRING ["You suffer a one-die penalty to interact with non-hostiles outside of Intimidation or inhuman ways"]
                }
                ^"Rating 4" DEF {
                    ^"Moral Guideline" STRING "Failing to kill when necessary"
                    ^"Rationale" STRING "Nothing is more important than survival"
                    ^"Effects" LIST OF STRING ["You suffer a two-dice penalty to interact with non-hostiles"]
                }
                ^"Rating 3" DEF {
                    ^"Moral Guideline" STRING "Not defending your territory"
                    ^"Rationale" STRING "Those who do not defend their territory have it taken from them"
                    ^"Effects" LIST OF STRING ["You suffer a four-dice penalty to interact with non-hostiles"]
                }
                ^"Rating 2" DEF {
                    ^"Moral Guideline" STRING "Showing your enemies mercy"
                    ^"Rationale" STRING "Mercy is for the weak"
                    ^"Effects" LIST OF STRING ["You suffer a six-dice penalty to interact with non-hostiles; Aura reduces the penalty to four"]
                }
                ^"Rating 1" DEF {
                    ^"Moral Guideline" STRING "Failing to feed your hunger"
                    ^"Rationale" STRING "The Beast must be satisfied"
                    ^"Effects" LIST OF STRING ["You suffer an eight-dice penalty to interact with non-hostiles; Aura reduces this to five"]
                }
            }
        }
        DESCRIPTION "Followers of Via Bestiae control their Beast through the primal concepts of survival, strength, and individuality. Many choose a simple, animalistic existence to best serve its beliefs; others live simply, akin to barbarians."
    }
    # ============================================================
    # Road of Humanity (Prodigals) — Via Humanitatis
    # ============================================================
    #wopRoadHumanity01 ^"Road of Humanity" DEF {
        EXTENDS ^"Road"
        PROPERTIES {
            ^"Latin Name" STRING "Via Humanitatis"
            ^"Followers" STRING "Prodigals"
            ^"Aura" STRING "Blush of Life"
            ^"Tenets" LIST OF STRING [
                "A man is measured by his words, his deeds and his heart, not an accident of birth or circumstance",
                "The ability to reason separates man from beast",
                "Do unto others as you would have them do unto you",
                "All men are brothers",
                "Freedom is earned with dignity and justice"
            ]
            ^"Hierarchy of Sins" DEF {
                ^"Rating 10" DEF {
                    ^"Moral Guideline" STRING "Selfish thoughts"
                    ^"Rationale" STRING "Thought is as good as deed"
                    ^"Effects" LIST OF STRING ["Permanently have the effects of Aura; appear as a healthy human", "Heal Superficial damage as a mortal", "You can taste, eat, and digest food as if human", "You can stay awake during the day as if human", "The rate of sunlight damage you take is halved"]
                }
                ^"Rating 9" DEF {
                    ^"Moral Guideline" STRING "Minor selfish acts"
                    ^"Rationale" STRING "Compassion separates us from the beasts"
                    ^"Effects" LIST OF STRING ["Permanently have the effects of Aura; appear as an ill human", "Heal Superficial damage as a mortal", "You can taste, eat, and digest rare or raw meat and many liquids", "You can rise from day-sleep up to an hour before sunset and stay awake an hour after dawn"]
                }
                ^"Rating 8" DEF {
                    ^"Moral Guideline" STRING "Injury to another person (deliberate or otherwise)"
                    ^"Rationale" STRING "Follow the golden rule"
                    ^"Effects" LIST OF STRING ["Roll two dice for the Aura Rouse check and take the highest result", "Aura allows you to digest and taste wine", "You can rise from day-sleep up to an hour before sunset"]
                }
                ^"Rating 7" DEF {
                    ^"Moral Guideline" STRING "Theft and robbery"
                    ^"Rationale" STRING "Respect the property of others"
                    ^"Effects" LIST OF STRING ["Unless using Aura, food and drink makes you immediately vomit unless a Composure + Stamina check is passed"]
                }
                ^"Rating 6" DEF {
                    ^"Moral Guideline" STRING "Accidental killing"
                    ^"Rationale" STRING "Ignorance does not excuse cruelty"
                    ^"Effects" LIST OF STRING ["With Aura, make a check to keep food and drink down for an hour"]
                }
                ^"Rating 5" DEF {
                    ^"Moral Guideline" STRING "Wanton destruction"
                    ^"Rationale" STRING "Man creates; beast destroys"
                    ^"Effects" LIST OF STRING ["You suffer a one-die penalty to interact with humans outside of Intimidation or inhuman ways"]
                }
                ^"Rating 4" DEF {
                    ^"Moral Guideline" STRING "Impassioned killing"
                    ^"Rationale" STRING "Those who act as beasts become beasts"
                    ^"Effects" LIST OF STRING ["You suffer a two-dice penalty to interact with humans", "Can no longer keep food or drink down, even with Aura"]
                }
                ^"Rating 3" DEF {
                    ^"Moral Guideline" STRING "Planned killing"
                    ^"Rationale" STRING "If you surrender to the Beast, you become its slave"
                    ^"Effects" LIST OF STRING ["You suffer a four-dice penalty to interact with humans"]
                }
                ^"Rating 2" DEF {
                    ^"Moral Guideline" STRING "Casual killing"
                    ^"Rationale" STRING "Others are worthy of respect"
                    ^"Effects" LIST OF STRING ["You suffer a six-dice penalty to interact with humans; Aura reduces the penalty to four"]
                }
                ^"Rating 1" DEF {
                    ^"Moral Guideline" STRING "The most heinous and demented acts"
                    ^"Rationale" STRING "Are you man or beast?"
                    ^"Effects" LIST OF STRING ["You suffer an eight-dice penalty to interact with humans; Aura reduces this to five"]
                }
            }
        }
        DESCRIPTION "Followers of Via Humanitatis use the human condition to fight their Beast, remembering the ordinary mortals they were before Caine's curse. They emphasize human virtues — freedom, the heart and soul, and reason as the separator of man from beast."
    }
    # ============================================================
    # Road of Heaven (Faithful) — Via Caeli
    # ============================================================
    #wopRoadHeaven00001 ^"Road of Heaven" DEF {
        EXTENDS ^"Road"
        PROPERTIES {
            ^"Latin Name" STRING "Via Caeli"
            ^"Followers" STRING "Faithful"
            ^"Aura" STRING "Holy Radiance"
            ^"Tenets" LIST OF STRING [
                "God laid His mark upon Caine and his childer are part of His great plan",
                "The word of God is law. Defiance of God is a sin that leads to damnation",
                "No one is above God's law",
                "Love and serve God in all things",
                "Deny the Devil through denial of the Beast and all creatures of Hell"
            ]
            ^"Hierarchy of Sins" DEF {
                ^"Rating 10" DEF {
                    ^"Moral Guideline" STRING "Violating any of the Ten Commandments"
                    ^"Rationale" STRING "God's word is law"
                    ^"Effects" LIST OF STRING ["Permanently have the effects of Aura; appear as a divine being", "Add 2 additional dice when resisting True Faith abilities"]
                }
                ^"Rating 9" DEF {
                    ^"Moral Guideline" STRING "Failing to speak out against corruption and sin"
                    ^"Rationale" STRING "All the Devil requires is for the faithful to do nothing"
                    ^"Effects" LIST OF STRING ["Blush of Life hides your undead aura from supernatural detection by non-Cainites", "Add 1 additional die when resisting True Faith abilities"]
                }
                ^"Rating 8" DEF {
                    ^"Moral Guideline" STRING "Acting out of pride, avarice, gluttony, or some other sinful impulse"
                    ^"Rationale" STRING "Sin is the road to the Beast"
                    ^"Effects" LIST OF STRING ["Roll two dice for the Aura Rouse check and take the highest result"]
                }
                ^"Rating 7" DEF {
                    ^"Moral Guideline" STRING "Theft, robbery, willful vandalism"
                    ^"Rationale" STRING "Thou shalt not steal"
                    ^"Effects" LIST OF STRING ["With Aura, add 2 dice to checks made to hide your undead aura from supernatural detection by non-Cainites"]
                }
                ^"Rating 6" DEF {
                    ^"Moral Guideline" STRING "Causing harm to pious and virtuous persons"
                    ^"Rationale" STRING "God sees all and punishes such sins"
                    ^"Effects" LIST OF STRING ["With Aura, add 1 die to checks made to hide your undead aura from supernatural detection by non-Cainites"]
                }
                ^"Rating 5" DEF {
                    ^"Moral Guideline" STRING "Feeding from an innocent without permission"
                    ^"Rationale" STRING "God protects the innocent"
                    ^"Effects" LIST OF STRING ["You suffer a one-die penalty to interact with pious humans outside of Intimidation or inhuman ways"]
                }
                ^"Rating 4" DEF {
                    ^"Moral Guideline" STRING "Blasphemous or heretical acts"
                    ^"Rationale" STRING "Denial of God leads only to damnation"
                    ^"Effects" LIST OF STRING ["You suffer a two-dice penalty to interact with pious humans"]
                }
                ^"Rating 3" DEF {
                    ^"Moral Guideline" STRING "Allowing crime or major sin to go unpunished"
                    ^"Rationale" STRING "Vengeance is mine, sayeth the Lord"
                    ^"Effects" LIST OF STRING ["You suffer a four-dice penalty to interact with the pious"]
                }
                ^"Rating 2" DEF {
                    ^"Moral Guideline" STRING "The murder of innocents"
                    ^"Rationale" STRING "Thou shalt not kill"
                    ^"Effects" LIST OF STRING ["You suffer a six-dice penalty to interact with the pious; Aura reduces the penalty to four"]
                }
                ^"Rating 1" DEF {
                    ^"Moral Guideline" STRING "Aiding a demon or other supernatural agent of evil"
                    ^"Rationale" STRING "Serve evil and you serve the Beast"
                    ^"Effects" LIST OF STRING ["You suffer an eight-dice penalty to interact with the pious; Aura reduces this to five"]
                }
            }
        }
        DESCRIPTION "To follow the Road of Heaven is to love and serve God, obey His laws (the Ten Commandments being a prime example), and never act to empower the Devil. Other rules and gods may be substituted depending on the religion, but the general idea is the same."
    }
    # ============================================================
    # Road of Kings (Scions) — Via Regalis
    # ============================================================
    #wopRoadKings000001 ^"Road of Kings" DEF {
        EXTENDS ^"Road"
        PROPERTIES {
            ^"Latin Name" STRING "Via Regalis"
            ^"Followers" STRING "Scions"
            ^"Aura" STRING "Air of Authority"
            ^"Tenets" LIST OF STRING [
                "There are only two roles in this world: that of master and that of servant",
                "You are superior to mortals, made to rule",
                "To master others, you must first master yourself and the Beast within",
                "Only those who seize power gain it; only those who use power keep it",
                "Your word is your bond. Without it, you are nothing"
            ]
            ^"Hierarchy of Sins" DEF {
                ^"Rating 10" DEF {
                    ^"Moral Guideline" STRING "Neglecting your duty"
                    ^"Rationale" STRING "Those who fail in their responsibilities often lose them"
                    ^"Effects" LIST OF STRING ["Permanently have the effects of Aura; appear as an authority figure", "You may use your Mending ability to heal Superficial Willpower instead of physical damage once a night"]
                }
                ^"Rating 9" DEF {
                    ^"Moral Guideline" STRING "Treating a peer with disrespect"
                    ^"Rationale" STRING "A leader earns respect by acting respectfully"
                    ^"Effects" LIST OF STRING ["Permanently have the effects of Blush of Life; appear as an important figure", "You heal your full Willpower rating in Superficial damage at the beginning of a session"]
                }
                ^"Rating 8" DEF {
                    ^"Moral Guideline" STRING "Treating an inferior as an equal"
                    ^"Rationale" STRING "Everyone should know their place, including you"
                    ^"Effects" LIST OF STRING ["Roll two dice for the Aura Rouse check and take the highest result", "While your Aura is active, you may re-roll one additional die when spending Willpower to do so"]
                }
                ^"Rating 7" DEF {
                    ^"Moral Guideline" STRING "Breaking your word to a peer"
                    ^"Rationale" STRING "Trust is earned by being trustworthy"
                    ^"Effects" LIST OF STRING ["While Aura is active, reduce any Superficial Willpower damage caused by Social Combat by two"]
                }
                ^"Rating 6" DEF {
                    ^"Moral Guideline" STRING "Behaving shamefully before your peers"
                    ^"Rationale" STRING "Honor and reputation are everything"
                    ^"Effects" LIST OF STRING ["While Aura is active, reduce any Superficial Willpower damage caused by Social Combat by one"]
                }
                ^"Rating 5" DEF {
                    ^"Moral Guideline" STRING "Showing weakness in front of your inferiors"
                    ^"Rationale" STRING "A leader must be seen as strong"
                    ^"Effects" LIST OF STRING ["You suffer a one-die penalty to interact with those of lower station"]
                }
                ^"Rating 4" DEF {
                    ^"Moral Guideline" STRING "Failing to answer a challenge to your honor"
                    ^"Rationale" STRING "Honor must be maintained; challenges cannot go unanswered"
                    ^"Effects" LIST OF STRING ["You suffer a two-dice penalty to interact with those of lower station"]
                }
                ^"Rating 3" DEF {
                    ^"Moral Guideline" STRING "Treating a superior with disrespect"
                    ^"Rationale" STRING "Superiors must be given the respect they are due"
                    ^"Effects" LIST OF STRING ["You suffer a four-dice penalty to interact with those of lower station"]
                }
                ^"Rating 2" DEF {
                    ^"Moral Guideline" STRING "Breaking your word to your superiors"
                    ^"Rationale" STRING "Your word is your bond; if your word is worthless, then so are you"
                    ^"Effects" LIST OF STRING ["You suffer a six-dice penalty to interact with those of lower station; Aura reduces the penalty to four"]
                }
                ^"Rating 1" DEF {
                    ^"Moral Guideline" STRING "Breaking a sworn oath"
                    ^"Rationale" STRING "Oaths of fealty hold the world together"
                    ^"Effects" LIST OF STRING ["You suffer an eight-dice penalty to interact with those of lower station; Aura reduces this to five"]
                }
            }
        }
        DESCRIPTION "Followers of Via Regalis control their Beast by ruling over others. Mortals are inferior, promises will be fulfilled, and power is everything."
    }
    SPEC_VERSION "0.4"
    # House rules for the War of Princes chronicle (London, 1242). Characters use the
    # standard V5 creation rules with the parameters below. The coterie is a
    # London-based, nomadic envoy of moderate status serving Mithras. Setting lore
    # (Mithras, the Rose Treaty, the governing powers, etc.) is narrative and lives in
    # a .lore/.setting companion, not here.
    #wopCharCreation001 ^"War of Princes Character Creation" DEF {
        DESCRIPTION "Standard V5 character creation with the following chronicle parameters. Use common sense to avoid predator types, backgrounds, and disciplines that only have modern applications; the Storyteller will adjust as needed."
        PROPERTIES {
            ^"Age" STRING "Neonate — embraced less than 100 years ago; the earliest a Cainite would be trusted with autonomy"
            ^"Generation" ENUM ["10th", "11th"]
            ^"Base Experience" INTEGER 15
            ^"Bonus Experience" INTEGER 30
            ^"Total Starting Experience" INTEGER 45
            ^"Free Languages Besides English" INTEGER 1
            ^"Max Flaw Dots For Advantages" INTEGER 7
            ^"Uses Touchstones And Convictions" BOOLEAN
            false
            ^"Morality System" STRING "Road"
            ^"Starting Road Rating" INTEGER 7
            ^"Available Roads" LIST OF ^"Road"
        }
        RULES {
            #wopCCRuleGen000001: play_a_10th_or_11th_generation_neonate_under_100_years_embraced
            #wopCCRuleXP0000001: start_with_45_total_experience_including_30_bonus
            #wopCCRuleLang00001: one_language_besides_english_is_free_linguistics_merit_required_for_more
            #wopCCRuleFlaws0001: spend_up_to_seven_flaw_dots_for_an_equal_number_of_advantage_dots
            #wopCCRuleNomad0001: avoid_modern_or_haven_bound_backgrounds_the_coterie_is_nomadic
            #wopCCRuleNoTouch01: touchstones_and_convictions_are_not_used_in_this_chronicle
            #wopCCRuleRoad00001: humanity_is_replaced_by_the_road_system_choose_one_road_starting_at_rating_7
        }
    }
    # ---- Clan availability (High / Low social standing in the Dark Ages) ----
    #wopHighClans000001 ^"High Clans" DEF {
        DESCRIPTION "Clans with greater social status. Generalizations that can fluctuate by domain."
        PROPERTIES {
            ^"Clans" LIST OF STRING ["Brujah", "Cappadocian", "Lasombra", "Toreador", "Tzimisce", "Ventrue"]
        }
    }
    #wopLowClans0000001 ^"Low Clans" DEF {
        DESCRIPTION "Clans with lesser social status. Some, as written in 5th edition, require adjustments to fit the Dark Ages setting."
        PROPERTIES {
            ^"Clans" LIST OF STRING ["Assamite", "Followers of Set", "Gangrel", "Malkavian", "Nosferatu", "Ravnos", "Tremere"]
        }
    }
    # ---- Traditions of Caine (social/legal framework most domains follow) ----
    #wopTraditions00001 ^"Traditions of Caine" DEF {
        DESCRIPTION "Most domains follow the Traditions of Caine. Mithras enforces his Blood Laws, which remove worship of Caine (the Covenant) as a rule."
        PROPERTIES {
            ^"Traditions" LIST OF STRING ["Covenant (Caine)", "Domain", "Progeny", "Accounting", "Destruction", "Silence (discretion in the Masquerade)"]
        }
    }
}

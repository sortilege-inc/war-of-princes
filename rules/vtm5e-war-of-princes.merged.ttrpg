BASE "vtm5e" {
    NAME "vtm5e — resolved composition"
    VERSION "0.4"
    # Generated by titterpig-synthesist from 6 source file(s).
    # Compiled artifact — do not edit; recompile from the composition manifest.
    SPEC_VERSION "0.4"
    # Split from consolidated VTM5e_Core v0.1.4
    # Section: core
    # Improvements in v0.1.7: Source file cleanup, "Bond Status" rename
    #VnK8MrPxWbGhN2fQ4sT6uW ACTOR "Entity" DEF {
        # The root of all actor types
        # All ACTORs ultimately extend from Entity
        PROPERTIES {
            ^"Name" STRING REQUIRED
            ^"Description" STRING
        }
        RULES {
            #A3bC5dE7fG9hI1jK3lM5n: WHEN [^"Entity" CREATED] THEN REQUIRE ^"Name"
        }
    }
    # ── Character base types (v0.4) ──────────────────────────────────────
    # A Character is any PC or NPC; a Supporting Character is an NPC; a
    # Character Relationship links two characters. Referenced by LIST OF in
    # scene / chronicle / coterie definitions (core, world).
    #vtmCharacterBase00001 ACTOR "Character" DEF {
        EXTENDS ^"Entity"
        PROPERTIES {
            ^"Concept" STRING
            ^"Player" STRING
        }
    }
    #vtmSupportingChar0001 ACTOR "Supporting Character" DEF {
        EXTENDS ^"Character"
        PROPERTIES {
            ^"Role" STRING
            ^"Disposition" STRING
        }
    }
    #vtmCharacterRel000001 ^"Character Relationship" DEF {
        PROPERTIES {
            ^"From" STRING REQUIRED
            ^"To" STRING REQUIRED
            ^"Nature" STRING
            ^"Description" STRING
        }
    }
    #X7yZ9aB1cD3eF5gH7iJ9kL ACTOR "Mortal" DEF {
        EXTENDS #VnK8MrPxWbGhN2fQ4sT6uW ^"Entity"
        # Living humans - the base mortal type
        # Source of vitae for vampires, potential childer
        PROPERTIES {
            ^"Health" INTEGER MIN 0 MAX 10 DEFAULT 3
            ^"Willpower" INTEGER MIN 0 MAX 10
            ^"Attributes" DEF {
                ^"Strength" INTEGER MIN 0 MAX 5 DEFAULT 1
                ^"Dexterity" INTEGER MIN 0 MAX 5 DEFAULT 1
                ^"Stamina" INTEGER MIN 0 MAX 5 DEFAULT 1
                ^"Charisma" INTEGER MIN 0 MAX 5 DEFAULT 1
                ^"Manipulation" INTEGER MIN 0 MAX 5 DEFAULT 1
                ^"Composure" INTEGER MIN 0 MAX 5 DEFAULT 1
                ^"Intelligence" INTEGER MIN 0 MAX 5 DEFAULT 1
                ^"Wits" INTEGER MIN 0 MAX 5 DEFAULT 1
                ^"Resolve" INTEGER MIN 0 MAX 5 DEFAULT 1
            }
            ^"Skills" LIST OF ^"Skill"
            ^"Humanity" INTEGER MIN 0 MAX 10 DEFAULT 7
            ^"Resonance" STRING
            ^"Blood" BOOLEAN DEFAULT true
        }
        RULES {
            #M5nO7pQ9rS1tU3vW5xY7z: WHEN [^"Mortal" TAKES DAMAGE] THEN REDUCE ^"Health"
            #B9cD1eF3gH5iJ7kL9mN1o: WHEN [^"Health" == 0] THEN ^"Mortal" IS incapacitated
            #P3qR5sT7uV9wX1yZ3aB5c: WHEN [^"Mortal" IS feeding_victim] THEN MAY PROVIDE ^"Resonance"
        }
    }
    #D7eF9gH1iJ3kL5mN7oP9q ACTOR "Ghoul" DEF {
        EXTENDS #X7yZ9aB1cD3eF5gH7iJ9kL ^"Mortal"
        # Mortals who have consumed vampire vitae
        # Gain some vampire powers but remain living
        PROPERTIES {
            ^"Blood Potency" INTEGER MIN 0 MAX 0 DEFAULT 0
            ^"Bond Status" DEF {
                ^"Regnant" STRING
                ^"Bond Level" INTEGER MIN 0 MAX 3
            }
            ^"Disciplines" LIST OF STRING
            ^"Vitae Dependency" BOOLEAN DEFAULT true
        }
        RULES {
            #R5sT7uV9wX1yZ3aB5cD7e: WHEN [^"Ghoul" NOT fed vitae] THEN AGE normally
            #F9gH1iJ3kL5mN7oP9qR1s: WHEN [^"Ghoul" FED vitae] THEN DOES NOT age
            #T3uV5wX7yZ9aB1cD3eF5g: WHEN [^"Ghoul" USES discipline] THEN USES ^"Blood Potency" 0
        }
    }
    #H1iJ3kL5mN7oP9qR1sT3u ACTOR "Hunter" DEF {
        EXTENDS #X7yZ9aB1cD3eF5gH7iJ9kL ^"Mortal"
        # Mortals who hunt vampires
        # May have special abilities or equipment
        PROPERTIES {
            ^"Organization" STRING
            ^"Hunter Type" ENUM ["Professional", "Devoted", "Opportunist"]
            ^"Edges" LIST OF STRING
        }
        RULES {
            #V5wX7yZ9aB1cD3eF5gH7i: WHEN [^"Hunter" DETECTS vampire] THEN MAY use ^"Edges"
            #J9kL1mN3oP5qR7sT9uV1w: WHEN [^"Hunter" IS Professional] THEN GAINS equipment_access
        }
    }
    #X3yZ5aB7cD9eF1gH3iJ5kL ACTOR "Kindred" DEF {
        EXTENDS #VnK8MrPxWbGhN2fQ4sT6uW ^"Entity"
        # Base vampire type - all vampires extend from this
        # The undead, cursed with the blood of Caine
        PROPERTIES {
            ^"Health" INTEGER MIN 0 MAX 10 DEFAULT 5
            ^"Willpower" INTEGER MIN 0 MAX 10
            ^"Skills" LIST OF ^"Skill"
            ^"Blood Potency" INTEGER MIN 0 MAX 10 DEFAULT 1
            ^"Hunger" INTEGER MIN 0 MAX 5 DEFAULT 1
            ^"Humanity" INTEGER MIN 0 MAX 10 DEFAULT 7
            ^"Generation" INTEGER MIN 4 MAX 16
            ^"Clan" STRING REQUIRED
            ^"Disciplines" LIST OF STRING
            ^"Merits" LIST OF STRING
            ^"Flaws" LIST OF STRING
            ^"Convictions" LIST OF STRING
            ^"Touchstones" LIST OF STRING
            ^"Ambition" STRING
            ^"Desire" STRING
            ^"Blood" BOOLEAN DEFAULT false
            ^"Resonance" STRING
        }
        RULES {
            #M7nO9pQ1rS3tU5vW7xY9z: WHEN [^"Kindred" TAKES DAMAGE] THEN MARK Superficial or Aggravated
            #A1bC3dE5fG7hI9jK1lM3n: WHEN [^"Hunger" == 5] THEN CANNOT feed normally
            #O5pQ7rS9tU1vW3xY5zA7b: WHEN [^"Humanity" == 0] THEN ^"Kindred" IS lost to Beast
            #C9dE1fG3hI5jK7lM9nO1p: WHEN [^"Kindred" EXPOSED to sunlight] THEN TAKE Aggravated damage
        }
    }
    #Q3rS5tU7vW9xY1zA3bC5d ACTOR "Thin-Blood" DEF {
        EXTENDS #X3yZ5aB7cD9eF1gH3iJ5kL ^"Kindred"
        # Weak-blooded vampires, 14th+ generation
        # Different rules and abilities
        PROPERTIES {
            ^"Blood Potency" INTEGER MIN 0 MAX 0 DEFAULT 0
            ^"Generation" INTEGER MIN 14 MAX 16
            ^"Clan" STRING DEFAULT "Caitiff"
            ^"Thin-Blood Merits" LIST OF STRING
            ^"Thin-Blood Flaws" LIST OF STRING
            ^"Daywalker" BOOLEAN DEFAULT false
        }
        RULES {
            #E7fG9hI1jK3lM5nO7pQ9r: WHEN [^"Thin-Blood" USES discipline] THEN MAY require Thin-Blood Alchemy
            #S1tU3vW5xY7zA9bC1dE3f: WHEN [^"Thin-Blood" IS ^"Daywalker"] THEN CAN tolerate sunlight
            #G5hI7jK9lM1nO3pQ5rS7t: WHEN [^"Thin-Blood" DIABLERIZES] THEN MAY increase ^"Blood Potency"
        }
    }
    #U9vW1xY3zA5bC7dE9fG1h ACTOR "Brujah" DEF {
        EXTENDS #X3yZ5aB7cD9eF1gH3iJ5kL ^"Kindred"
        PROPERTIES {
            ^"Clan" STRING "Brujah" FIXED
            ^"In-Clan Disciplines" LIST OF STRING ["Celerity", "Potence", "Presence"]
            ^"Clan Bane" STRING "Violent Temper"
            ^"Clan Compulsion" STRING "Rebellion"
        }
        RULES {
            #I3jK5lM7nO9pQ1rS3tU5v: WHEN [^"Brujah" SUFFERS ^"Clan Compulsion"] THEN MUST rebel against authority
        }
    }
    #W7xY9zA1bC3dE5fG7hI9j ACTOR "Gangrel" DEF {
        EXTENDS #X3yZ5aB7cD9eF1gH3iJ5kL ^"Kindred"
        PROPERTIES {

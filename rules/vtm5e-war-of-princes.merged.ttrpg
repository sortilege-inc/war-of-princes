            #cvvotsoNKoTPiXPgtVLgpN: tracking_ability
            #n5pdcGTSvcBzpKYQ7hzJE3: shelter_creation
        }
    }
    ^"Skill" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Learned abilities that define how characters reliably apply
        # their potential. Combined with Attributes to form dice pools.
        RULES {
            #X7BFL63B3nQyRUnUX3bevw: learned_application
            #ntD9ML3yx5n54rZD2ckisC: skill_pools
            #aYsjDtHrctpv89LKFxtK9Y: specialization_bonus
        }
    }
    ^"Animal Ken" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Allows you to cow, pacify, and befriend animals. Predict animal reactions,
        # train domesticated creatures, calm or enrage animals. Without this Skill,
        # most creatures avoid or grow aggressive around vampires.
        SPECIALTIES ["Attack Training", "Cats", "Dogs", "Falconry", "Horses", "Pacification", "Rats", "Snakes", "Stunt Training", "Wolves"]
        RULES {
            #FpkMC3MGdT9bBDWKnNWFGZ: animal_pacification
            #6BK5G77W5eHZDcZfziPaZR: training_commands
            #eHnJTSKtJpSkVsxi3vULDv: vampire_animal_reaction
        }
    }
    ^"Etiquette" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Ability to identify and respond to social conventions, set new protocols,
        # and please everyone with your good graces. Used in both Kindred and
        # mortal high society.
        SPECIALTIES ["Anarch", "Camarilla", "Celebrities", "Corporate", "Elysium", "Feudal", "One-Percenter", "Secret Society"]
        RULES {
            #d56mZXauLJbwCHuYPWpLoE: social_protocol_knowledge
            #eafYvdQiY3jiFa6nuZUnGb: faux_pas_avoidance
            #J7a5EEkm5pULoMxWDYEPJk: trend_setting
        }
    }
    ^"Insight" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Grants ability to interpret body language, note subtle cues, determine
        # truth from lies. Allows you to perceive and understand motives behind
        # another's actions.
        SPECIALTIES ["Ambitions", "Desires", "Detect Lies", "Emotions", "Empathy", "Interrogation", "Motives", "Phobias", "Vices"]
        RULES {
            #Q2jNDrp5C98xWhYHof38Fm: lie_detection
            #3vmZa8PuwXHMgwV4AQp3mP: emotional_reading
            #R3CTmeHrx3EbnKBqALz38o: motive_analysis
        }
    }
    ^"Intimidation" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        # Coercing compliance through perceived or actual threats. Passive
        # intimidation provides social space while active intimidation forces
        # immediate backing down from confrontation.
        SPECIALTIES ["Direct Threats", "Innuendo", "Physical Coercion", "Political Pressure", "Torture", "Veiled Threats"]
        RULES {
            #5XNdyKai6Z7NmnAZmYyGYN: fear_generation
            #Sq2RTf3K6FtZTUMCMSWUvq: coercion_techniques
            #QC2A8fcTYgsVHDEemzbVzu: will_breaking
            #a4kVaybjN5ZrVuWgrpWEKa: passive_social_spacing
            #BfMeNBua7MQ6A9XGMvfHLX: active_intimidation_rating
            #SEcvLAgVtshKTXd7GWqPj3: subtle_coercion
            #SNktnKoEHEGSqUk8NkKDwa: blatant_threats
            #VDyCb9S9Deuv4RFo2jr7DA: physical_escalation
            #dHQGm2U5tBaBDojeLg9Geu: backing_down_contest
            #HfG3fsrQBDAv8kL6vbwV3g: superficial_damage
        }
    }
    ^"Leadership" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Grants ability to lead crowds, command detachments, boost supporter morale,
        # or subdue riots. Strong Princes or Barons must possess Leadership or risk
        # losing their throne.
        SPECIALTIES ["Command", "Inspiration", "Military", "Motivation", "Small Groups", "Strategy", "Tactics"]
        RULES {
            #FS8tD4JMJwCngHnezh6WVi: group_coordination
            #J3XAEsYEhsgTMJ2mVnQx5U: morale_boosting
            #kfNi8gvU7GhYvZCJjdRgs2: authority_projection
        }
    }
    ^"Performance" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Covers range of arts from dance to poetry, comedy to storytelling.
        # May be inspired performer or enthusiastic student of the arts.
        # Grants one free specialty when acquired.
        SPECIALTIES ["Comedy", "Dance", "Drama", "Drums", "Guitar", "Keyboards", "Poetry", "Public Speaking", "Rap", "Singing", "Violin", "Wind Instruments"]
        RULES {
            #efag4QavNNn7VtZA3T9T5b: artistic_expression
            #XW5LKwBwwpGT29XchTZnSU: audience_engagement
            #bBsNuSxApdRQiQaWjjCzge: improvisation_ability
        }
    }
    ^"Persuasion" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Use when trying to convince others you know what's best, and that one
        # bite won't hurt. Play on victims' emotions and appeal to peers' reason.
        # Applies in law courts, princely courts, boardrooms, barrooms, and bedrooms.
        SPECIALTIES ["Bargaining", "Fast Talk", "Interrogation", "Legal Argument", "Negotiation", "Rhetoric"]
        RULES {
            #BNfdyAwoNsdkMhJt5SYmmR: conviction_techniques
            #GuspK7HGCX2axA7LDJdhoF: emotional_manipulation
            #eMszWYFuB7JXTnYU96uj2b: logical_argumentation
        }
    }
    ^"Streetwise" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Enables characters to talk the language and negotiate societies of streets
        # and underworld. Understand code words, slang, interpret graffiti tags,
        # and emulate gang signs.
        SPECIALTIES ["Arms Dealing", "Black Market", "Bribery", "Drugs", "Fence Stolen Goods", "Gangs", "Graffiti", "Personal Rep", "Sex Trade", "Urban Survival"]
        RULES {
            #jiTCoALyqCGp5qL28eYFHk: criminal_network_access
            #jfsgLoPJg6RKJaMvYjbmda: street_information
            #ftm9Jjhrn6RH64cGTLExNB: underworld_navigation
        }
    }
    ^"Subterfuge" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Art of lying convincingly, spinning yarns, making good excuses for bad actions.
        # Defines talent for intrigue, secrets, and double-dealing. Also used for
        # seduction and imitating mortal behavior.
        SPECIALTIES ["Bluff", "Feign Mortality", "Impeccable Lies", "Innocence", "The Long Con", "Seduction"]
        RULES {
            #meMck3XzEZyY95PALbR7eE: deception_mastery
            #7uBMSkeYRmBCk2rnCzT5Bb: identity_concealment
            #Pgy9bKCWHu9SiBioyTJVFA: intrigue_navigation
        }
    }
    ^"Academics" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Reflects understanding, higher education, and ability to research fields
        # within humanities and liberal arts. Historical study is critical if
        # your immortal enemies left traces in that period.
        # Grants one free specialty when acquired.
        SPECIALTIES ["Architecture", "English Literature", "History of Art", "History (specific Field or Period)", "Journalism", "Philosophy", "Research", "Teaching", "Theology"]
        RULES {
            #LL4YtFBBHZPQnm3ULAWHUC: research_ability
            #Wra9sU82WiNgRgqukSM8FQ: historical_knowledge
            #MpT5C4qTj7LLRy8nEtUKTv: cultural_understanding
        }
    }
    ^"Awareness" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Handles your perceptions. Spot a Child of Haqim before a strike occurs,
        # spy a key dropped in trash, or sense a lingering perfume.
        SPECIALTIES ["Ambushes", "Camouflage", "Concealed Objects", "Hearing", "Instincts", "Smell", "Sight", "Traps", "Wilderness"]
        RULES {
            #C653PDEyjZcanoZdypuYtz: perception_enhancement
            #QoFhQVAjePnYe3fjskBCub: danger_detection
            #WKPoqGsH9z6ZFLqYiPnZQo: environmental_awareness
        }
    }
    ^"Finance" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Allows you to identify market trends, invest well, manipulate stock,
        # know when a fall is coming. Assess and trace others' wealth, broker
        # financial deals. Ventrue value this Skill more than some Disciplines.
        SPECIALTIES ["Appraisal", "Banking", "Black Markets", "Corporate Finance", "Currency Manipulation", "Fine Art", "Forensic Accounting", "Money Laundering", "Stock Market"]
        RULES {
            #A7N5HtPA4EwwNKGwieNiS8: market_analysis
            #QTeXnqxXnLGCMnfgrhCPbv: wealth_assessment
            #VWH9FezrVSfHLEEv5w9Anb: financial_manipulation
        }
    }
    ^"Investigation" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Allows you to unravel cases of mundane and mysterious means, spot clues,
        # interpret them, and trace missing persons. Vampires find this especially
        # useful when a vessel escapes.
        SPECIALTIES ["Criminology", "Deduction", "Forensics", "Missing Persons", "Murder", "Paranormal Mysteries", "Traffic Analysis"]
        RULES {
            #V6qhKwF8QFj9wpGZ8JojCJ: clue_analysis
            #gMAhjonmMJMJwEW8LHuw5J: case_reconstruction
            #dVus52Kk2nS6ExcXgtNdyN: evidence_interpretation
        }
    }
    ^"Medicine" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Allows you to fix people who are broken and diagnose causes of death
        # or sickness. Use medical equipment, prescribe drugs, and stanch or
        # encourage rapid blood flow.
        SPECIALTIES ["First Aid", "Haematology", "Pathology", "Pharmacy", "Phlebotomy", "Surgery", "Trauma Care", "Veterinary"]
        RULES {
            #Wk24F3Lnhh3jNv8XEuBJ8u: healing_techniques
            #UHDt7wkBkRhmfb3BDo4Nex: diagnosis_ability
            #CfhUHpyxdLmRkKNWo5tmqN: medical_equipment_use
        }
    }
    ^"Occult" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Represents knowledge of the mystical world, from Freemason rites to
        # Noddist scholars and real mages. Recognize occult sigils and folk-magic
        # practices, effective or not.
        SPECIALTIES ["Alchemy", "Blood Magic", "Faeries", "Ghosts", "Grimoires", "Infernalism", "Magi", "Necromancy", "Noddism", "Parapsychology", "Voudun", "Werewolves"]
        RULES {
            #PAZhygdKQ5ZAGbr5tfs7vq: supernatural_lore
            #APdh8XumA3uNPMVXaHAWam: ritual_knowledge
            #X4KS6T6EusvcEYhApVUoXX: mystical_identification
        }
    }
    ^"Politics" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # and pressure city government and perhaps higher levels. Among Kindred,
        # know which sects dominate where, who wars with whom, where bodies are buried.
        SPECIALTIES ["Anarchs", "Camarilla", "City Government", "Clan (specific)", "Diplomacy", "Media", "National Politics", "State/Provincial Politics"]
        RULES {
            #AnkdSqKEYPZZoNjjrJVBa7: political_maneuvering
            #VzrwiA2HP2HSwKRV83ZFWZ: bureaucracy_navigation
            #NHWwXrE7dq3zRHTJVh8Wrt: faction_knowledge
        }
    }
    ^"Science" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Broad church covering everything from basic principles of life to
        # understanding of universal entropy. Laws of science govern the mortal
        # world, and vampires who wish to rule study them.
        # Grants one free specialty when acquired.
        SPECIALTIES ["Astronomy", "Biology", "Chemistry", "Demolitions", "Engineering", "Genetics", "Geology", "Mathematics", "Physics"]
        RULES {
            #9rrmy6fjkvQdqKHDHXLkKi: scientific_analysis
            #JZiAVFGvKToZjrVJcPLy2w: research_methodology
            #L5zFYki7AHLkvmFUswT9A5: technological_understanding
        }
    }
    ^"Technology" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Governs operation and understanding of "technical developments most
        # vampires find mystifying." These nights, governs computers and computer
        # systems that control almost everything.
        SPECIALTIES ["Algorithms", "Computer Graphics", "Cryptography", "Data Retrieval", "Hacking", "Internet", "Security", "Social Media"]
        RULES {
            #Gm4fEnJr8XR3kKTorF2upD: computer_operation
            #7yKQQJsVzvHdFQFetSbfZY: digital_security
            #BqhnkDuY2zRB3tWzF9BEVP: system_manipulation
        }
    }
    ^"Blood Bond Strength" DEF {
        APPLIES TO [^"Kindred"]
        INTEGER MIN 0 MAX 6
        # Strength of supernatural loyalty created by consuming vampire blood.
        # Increases by 1 for each time thrall drinks regnant's blood (max 6).
        # Decreases by 1 each month without consumption. Creates obsessive
        # devotion at higher levels.
        RULES {
            #H5EjwSyUZagxNiM2eEMSft: defiance_resistance
            #3hgCF44EqPHbPffddXkvP5: monthly_degradation
            #nNd82hLCbLDCBcKLsJNvXM: potency_limits
        }
    }
    ^"Attribute Priority" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        ENUM ["Primary", "Secondary", "Tertiary"]
        # Priority system for attribute distribution during character creation.
        # Primary gets most dots, secondary moderate, tertiary least.
        ATTRIBUTE_CATEGORIES {
            "Physical"
            ["Strength", "Dexterity", "Stamina"]
            "Social"
            ["Charisma", "Manipulation", "Composure"]
            "Mental"
            ["Intelligence", "Wits", "Resolve"]
        }
        RULES {
            #FxmdmpqERJVcdbx2qawJfB: priority_distribution_system
            #ERu7p8Vt6Vt3VsBD4fiFR8: category_assignment_limits
        }
    }
    ^"Skill Assignment Method" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        ENUM ["Jack_Of_All_Trades", "Balanced", "Specialist"]
        # Different approaches to skill point distribution during creation.
        # Each method provides different patterns of breadth vs depth.
        DISTRIBUTION_PATTERNS {
            "Jack_Of_All_Trades"
            {
                SKILLS_AT_3 1
                SKILLS_AT_2 8  
                SKILLS_AT_1 10
            }
            "Balanced"
            {
                SKILLS_AT_3 3
                SKILLS_AT_2 5
                SKILLS_AT_1 7
            }
            "Specialist"
            {
                SKILLS_AT_4 1
                SKILLS_AT_3 3
                SKILLS_AT_2 3
                SKILLS_AT_1 3
            }
        }
        RULES {
            #Hese6VKqUEWNzicuhTR7jd: distribution_method_selection
            #EMV9poVyphndMZLYUuEDep: free_specialty_grants
        }
    }
    ^"Artistic Performance" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        DICE_POOLS ["Charisma + Performance"]
        # Live performance before an audience including music, theater, dance,
        # or spoken word. Quality depends on successes achieved. Total failure
        # may create enemies among critical Toreador audiences.
        RULES {
            #3sGPg9uYDuxgz4R7A7THfK: live_audience_requirement
            #kdcJL5SMhFtsHukjjGoZPF: quality_by_successes
            #Q5TE2RoQFAJkTABD6wJPsx: purpose_indication
            #iiajPqFmYsTxT2YrKhKuZE: critical_failure_consequences
            #mS3kg8rdEKy8PX7FsyB4gQ: toreador_criticism
        }
    }
    ^"Feats of Strength" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        DICE_POOLS ["Strength + Athletics"]
        STRENGTH_CHART_REFERENCE
        True
        # Lifting, breaking, throwing, or destroying objects through raw physical
        # power. Chart provides guidelines for minimum strength requirements
        # for various feats without requiring tests.
        RULES {
            #bGFk249jEjnuMLEXFrHnwM: lifting_capacity_chart
            #nocDtBiwzv7ssSz8JWAt3Y: breaking_thresholds
            #FXnUxHgArnoz2zSELHtYkB: throwing_calculations
            #fsjQP2EBrGHEykCUTbA6dk: potence_enhancement
            #6Yz3ymtPF4aUF32FCdTFUf: all_or_nothing_results
            #mEQk5jVVCUa6HMz8aJkSDV: dragging_modifiers
        }
    }
    ^"Predatory Metaphor Awareness" DEF {
        SAFETY_PRINCIPLE
        Content_Warning
        # Vampires have historically been metaphors for human predation, including
        # sexual predation. The Kiss and feeding mechanics carry sexual undertones
        # that require careful handling at the table.
        RULES {
            #TS8axPHAn4hPvDNmgFYfAb: metaphor_recognition
            #atFyXu35dhfnHi2tsUvNUJ: feeding_scene_awareness
            #Q4AatYhnKswem9tBew8uuy: consent_violation_recognition
            #JTmbEvaJURH4FyKuSiFLmt: ethical_predator_options
            #Ejysri95dwQYoTR7rbAvbD: chronicle_tenet_alignment
        }
    }
    ^"Sabbat Occultation" DEF {
        APPLIES TO [^"Kindred"]
        BOOLEAN DEFAULT true
        # The Sabbat has largely disappeared from visible territories,
        # re-emerging as shadowy terror force. More dangerous as
        # hidden threat than organized sect.
        RULES {
            #kGvoc2pmC8cMx9nXYqQtN5: territorial_withdrawal
            #RXGixMcWwSD3SsLVWyxmTW: guerrilla_operations
            #PCYetpcRCQxTVPZiBip47B: masquerade_as_anarchs
            #8J9VsXaiUzChxvH2HYT5Va: experienced_agent_freedom
        }
    }
    ^"Skill Specialty" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        STRING
        # Particular expertise in one aspect of a Skill. Field where character
        # may be especially practiced, have special aptitude, or engaged in
        # deeper study. Grants one extra die when task falls under specialty.
        # 
        # Can only apply one specialty to a single roll. Generally can only have
        # as many specialties as dots in the Skill.
        RULES {
            #4o4GXajNwsketGuriJAx6C: bonus_die_when_applicable
            #Qg5JeyUg2AJ3uHTKxaS7UT: one_per_roll_limit
            #bWsuRmoR43H2a7cyX5wVTN: skill_dot_limitation
            #TcVLStYVVSkAr3uSAPciyt: three_experience_point_cost
        }
    }
    ^"Specialty" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        # Greater aptitude in one particular aspect of a Skill.
        # Grants one extra die when the action falls within the specialty.
        RULES {
            #cthXEqHZSHQQ6MC8uhmECS: focused_expertise
            #UnHZLmuzhwwnNoqPgEPhL3: bonus_die_award
        }
    }
    SPEC_VERSION "0.4"
    # Split from consolidated VTM5e_Core v0.1.4
    # Section: systems
    # Improvements in v0.1.7: Source file cleanup, "Bond Status" rename
    ^"Combat Type" DEF {
        ENUM ["Close Combat", "Ranged Combat"]
        # Different combat systems with specific rules for close quarters
        # versus ranged weapon engagements.
        RULES {
            #SBhRqZ9PZ79zuYP4QRZt38: close_combat_pools
            #8aKioErCN8SMt9XNhhgKp4: ranged_combat_pools
            #nTC4bqxyy9jiQ8W79bRSc4: grappling_mechanics
            #VYAp5vpfrVnkFUgFezT6QM: ranged_defense_modifiers
        }
    }
    ^"Hunger" DEF {
        APPLIES TO [^"Kindred"]
        INTEGER MIN 0 MAX 5
        # Supernatural thirst for blood. Affects dice pools, social interactions,
        # and frenzy thresholds. Increases through power use and time passage.
        RULES {
            #QmzvG98QGi3pR53W4vMJ7s: hunger_dice_substitution
            #kNzwXQ6BAwtFzXZgn6taRg: social_interaction_penalties
            #XZjHXHHiWSitS2ca3j5pP6: frenzy_threshold_modification
            #CWiHiR8qnhpGN9rpheZeXb: rouse_check_consequences
            #hmjtqkjkWfJPJYRZ3VU6Rd: MODIFY: WHEN ^"Hunger Dice" SHOWS 10 IN ^"Critical Pair" THEN #Ge42RxKEejJFxJAfHqBx5n ^"Messy Critical" TRIGGERED
        }
    }
    ^"Blood Potency" DEF {
        APPLIES TO [^"Kindred"]
        INTEGER MIN 0 MAX 10
        # Supernatural power concentration in vampire's blood. Affects
        # discipline power, feeding requirements, and blood surge capabilities.
        DERIVED_PROPERTIES {
            ^"Blood Surge"
            STRING
            ^"Mend Amount"
            STRING
            ^"Power Bonus"
            STRING
            ^"Rouse Re-Roll"
            STRING
            ^"Feeding Penalty"
            STRING
            ^"Bane Severity"
            STRING
        }
        RULES {
            #97wLu3YrUVEXhMa52WRSvy: power_level_scaling
            #Hz7BJCrrjBstw59nMcHG2s: feeding_restrictions
            #FfBomAhJSexiZVZPtSikPk: discipline_limitations
            #5Gpn6DrSZpCSsXysL5hJrm: MODIFY: blood_surge_mechanics NOW REFERENCES #YD4PosFYGnnbWia88WUziU ^"Blood Surge Table"
            #2sft6ZqxgoBCXu9AQcZEFA: WHEN [REFERENCING ^"Blood Potency" EFFECTS] THEN USE #YD4PosFYGnnbWia88WUziU AND #j3R4UBSHhb2PCJRiA2QrBQ tables
            #KRfYvH9PXruj6cQ4ukcB7u: WHEN [^"Blood Potency" INCREASES] THEN ^"Blood Surge" AND ^"Bane Severity" BOTH increase per tables
            #fb7x38YYSvfkYXhoQwxtpz: WHEN [^"Character Creation"] THEN START with updated values from beginning
        }
    }
    ^"Humanity" DEF {
        APPLIES TO [^"Kindred"]
        INTEGER MIN 0 MAX 10
        # Vampire's connection to mortal nature and moral compass. Determines
        # frenzy resistance, social interaction penalties, and physical changes.
        # Lost through inhuman acts, regained through exceptional moral choices.
        # 
        RULES {
            #eECQedjov4XKgmNpBP7zfN: frenzy_resistance_bonus
            #n8zPGW9QLckFLTpwYwrPmP: social_interaction_penalties
            #MQrXthvHXG2GAvhdtvtXtS: physical_appearance_changes
            #XCLyzaXfjnuGaLCwgnuAHE: torpor_duration_effects
            #4LBPBCoyN7KgEtZUjY2WPP: blush_of_life_requirements
            #JNbhSxmaZc44BrARP8Xriy: stain_accumulation
            #MT9b89PyefjLNPDwyCJhQw: remorse_test_mechanics
            #MULKDxZHx9SwwWNNKfhX56: degeneration_consequences
            #R6Uxif7eEgJfmRCPz3gMfW: beast_resistance_bonuses
        }
    }
    ^"Blood Resonance" DEF {
        APPLIES TO [^"Kindred"]
        ENUM ["None", "Choleric", "Melancholic", "Phlegmatic", "Sanguine", "Animal"]
        # Blood type expressed as Resonance based on the four humors of classical
        # medicine. Resonance flavors blood and provides discipline bonuses when
        # consumed by vampires. Based on victim's temperament and emotional state.
        # 
        # Choleric: Angry, violent, passionate (Fire element, Adrenaline)
        # Melancholic: Sad, scared, intellectual (Earth element, Thyroid)
        # Phlegmatic: Lazy, apathetic, calm (Water element, Pituitary)
        # Sanguine: Horny, happy, enthusiastic (Air element, Testosterone/Estrogen)
        # Animal: From non-human sources, supports Animalism and Protean
        RULES {
            #j8cjPd6xpUZnYt3LH5fAZk: discipline_bonuses
            #PUWxsWMgmBCeRW6KuscfHx: temperament_effects
            #KJTtKNWw3YnDCpfuh6C3TS: dyscrasia_benefits
        }
    }
    ^"Resonance Temperament" DEF {
        APPLIES TO [^"Kindred"]
        ENUM ["Fleeting", "Intense", "Acute"]
        # Strength of resonance in victim's blood:
        # Fleeting: Momentary emotional state, no mechanical effect except flavor
        # Intense: Strong tendency toward one resonance, grants +1 die to associated disciplines
        # Acute: Self-sustaining reaction creating Dyscrasia with special benefits
        RULES {
            #aofjoBFTj6dQQkNtpu8W72: intensity_bonuses
            #Hi32xQpLgdikinUygZe6VN: dyscrasia_requirements
        }
    }
    ^"Dyscrasia" DEF {
        APPLIES TO [^"Kindred"]
        STRING
        # Acute resonances that create special supernatural effects beyond
        # normal discipline bonuses. Also called "clots" by younger vampires.
        # Each dyscrasia provides unique benefits when consumed properly.
        # 
        # Examples: "bully", "cycle of violence", "envy", "principled", "vengeful",
        # "in mourning", "lost love", "massive failure", "nostalgic", "chill",
        # "comfortably numb", "given up", "contagious enthusiasm", "true love"
        RULES {
            #Tq9Y2YoZS8GyE9tWZ2448a: special_effects
            #QsztkNVpJsCB7tAXXMendu: consumption_requirements
            #mhpanK7XbWqPwheEy7os44: duration_limits
        }
    }
    ^"Health" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0
        # Physical condition and injury resistance. Can sustain both
        # superficial and aggravated damage types.
        CONSTRAINTS {
            ^"Superficial Damage"
            + ^"Aggravated Damage" <= MAX
            ^"Superficial Damage"
            <= MAX - ^"Aggravated Damage"
        }
        CONSTRAINTS {
            ^"Superficial Damage"
            + ^"Aggravated Damage" <= MAX
            ^"Superficial Damage"
            <= MAX - ^"Aggravated Damage"
        }
        DAMAGE_TYPES {
            ^"Superficial Damage"
            INTEGER MIN 0
            ^"Aggravated Damage"
            INTEGER MIN 0
        }
        DAMAGE_TYPES {
            ^"Superficial Damage"
            INTEGER MIN 0
            ^"Aggravated Damage"
            INTEGER MIN 0
        }
        RULES {
            #fYHjLfFdPUpGSuZomGegXj: damage_calculation
            #aycqGuy9rc28ss6UBvKbyf: impairment_threshold
            #PeEanGB8qnkaJLJWgnqwfy: healing_mechanics
            #K4xadBSGRJ55HScK8Kao2h: damage_type_interactions
            #mb57sFAKFwGWHATkTZyE6m: damage_application_order
            #FFcCtaUBKEyRgqdyuzTUBA: incapacitation_condition
            #44FucUqJNTJ7MrjR35j4Lc: healing_mechanics
        }
    }
    ^"Willpower" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0
        # Mental determination and supernatural resistance. Spent to boost
        # dice pools, resist powers, and overcome compulsions.
        RULES {
            #abds5f94xkjmhuKkCvaqr2: dice_pool_bonuses
            #Mn9eT95H86hgWZhkkLMc7t: power_resistance
            #ZxptNYTW2ZJNYdMDqoDLj8: compulsion_resistance
            #ffStQ2cweHvk2hD7ikJuPY: recovery_methods
            #D8TDWLMVVXRnagpARqY9od: reroll_mechanics
            #dcaYMH78SWwEyYqpiCainC: resistance_bonus
            #behTszZiCSm8bZDQtvhTuM: recovery_conditions
        }
    }
    ^"Superficial Damage" DEF {
        # Causes bruising, sprains, and non-life-threatening injury.
        # Fists, kicks, and non-lethal weapons cause this to humans.
        # Standard weapons cause this to vampires.
        RULES {
            #gTyYWXNBGzuVTARopFTiVD: superficial_sources
            #FQs692pgULqup6MLp37bDN: halving_rule
            #MP7uNbYRsnDwUfunCdBzt4: healing_rate
        }
    }
    ^"Aggravated Damage" DEF {
        # Causes broken bones, wounds, and life-threatening injuries.
        # Sharp/piercing weapons cause this to humans. Fire, sunlight,
        # and supernatural claws/teeth cause this to vampires.
        RULES {
            #DvZoWhJPUaGgxvKxGy8CpL: aggravated_sources
            #ePzQuevD5gFuMvbhTrsdQm: full_damage_application
            #87z7HytCSydvvdMVMUYFdX: slow_healing
        }
    }
    ^"Weapon Damage Rating" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 6
        # Damage bonus added to successful attack margins to determine
        # total damage inflicted by different weapon types.
        RULES {
            #9yC6J8JFi4HsgcPMWYS95w: damage_bonus
            #bMdsxR3CGoJj38hzUTzV9K: stake_special_rule
        }
    }
    ^"Armor Value" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 6
        # Damage mitigation that converts Aggravated damage from puncturing
        # or bladed weapons to Superficial damage.
        RULES {
            #PLRX9zZef89JADj4vEe82U: damage_conversion
        }
    }
    ^"Crippling Injury" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        # Additional injury effects for characters taking damage while
        # already Impaired, adding tactical consequences to combat.
        RULES {
            #Ta5LCtpt7QRWtv7q3gM8QA: injury_trigger
            #FGoFhVXbRD96Gf8rpkpSBY: injury_effects
        }
    }
    ^"Called Shot" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        # Targeted attacks aimed at specific body parts or objects,
        # trading accuracy for specific effects.
        RULES {
            #SAvXNNiXWWrqbtpUQSodLd: success_penalty
            #3Ro8TgtZFb7bZRnpVaJpjh: specific_effects
        }
    }
    ^"Regnant" DEF {
        APPLIES TO [^"Kindred"]
        STRING
        # The vampire whose blood creates the Blood Bond. Can maintain thralls
        # equal to their Blood Potency rating. Thrall becomes immune to other
        # bonding attempts while bound.
        RULES {
            #4DH8W2kDWV3LQjnfsjGLdY: thrall_limits
            #MzbXYDS2CC7trTN72V8BLm: exclusive_bonding
            #mzKy2cQBLaVpPfVbeQuLy2: regnant_bond_master
            #a8Yo5ydqHT3U6uKUrLfWLZ: regnant_mystical_dominance
        }
    }
    ^"Thrall" DEF {
        APPLIES TO [^"Kindred"]
        BOOLEAN DEFAULT false
        # Individual bound by Blood Bond to a regnant. Experiences loyalty,
        # infatuation, and eventual terror of displeasing their regnant.
        # Cannot be bound to multiple regnants simultaneously.
        RULES {
            #aEkzKxkreptB8WREBb3Hs9: loyalty_compulsion
            #7QiKzoxaVVBYGkTjRcfmtY: defiance_tests
            #Cu7vsbewT7wguofU7gD3EE: thrall_blood_bond_victim
            #jFhXuF4UWj2WC8YBFAbfQJ: thrall_supernatural_loyalty
        }
    }
    ^"Ghoul Bond Level" DEF {
        APPLIES TO [^"Mortal"]
        INTEGER MIN 0 MAX 6
        # Blood Bond strength for ghouls. Single vampire can maintain unlimited
        # ghouls as long as they can supply vitae. Ghouls age rapidly if deprived
        # of vampire blood after extended periods of consumption.
        RULES {
            #S5rVrUicnMg9sU3JDfcFsP: unlimited_bonds
            #5HB4aP5FZn5j9fFVLXwVzD: withdrawal_effects
        }
    }
    ^"Diablerie Attempts" DEF {
        APPLIES TO [^"Kindred"]
        INTEGER MIN 0 MAX 999
        # Count of diablerie attempts made by vampire. Each successful diablerie
        # leaves permanent aural stains visible to those with supernatural sight.
        # Considered ultimate sin by most vampire societies.
        RULES {
            #AyauhiooZXDcEaGvSL3e8X: aura_staining
            #jUHuK8rwSN2A8tEzMFyYwS: social_consequences
            #3FDbAUPyKWJqSM6oZmsxAb: generation_reduction
        }
    }
    ^"Diablerie Success" DEF {
        APPLIES TO [^"Kindred"]
        INTEGER MIN 0 MAX 999
        # Count of successful diableries. Each success can lower generation,
        # increase Blood Potency, and grant victim's disciplines. Requires
        # winning contested rolls against victim's spiritual resistance.
        RULES {
            #bHkrA8mXZFseJLHFnD95MP: power_absorption
            #BTyEJBVGcwtAWEK6grnamD: humanity_loss
            #RazNxovwaaVPqHbrgVTx8p: spiritual_contest
        }
    }
    ^"Blood Bond Risk" DEF {

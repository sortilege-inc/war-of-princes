        }
    }
    ^"Athletics" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Allows you to outpace someone in pursuit, leap out of the way of an
        # oncoming car, and climb and swim like a healthy, robust living person.
        # Can be used in place of any Physical combat Skill but inflicts no damage.
        SPECIALTIES ["Acrobatics", "Archery", "Climbing", "Endurance", "Jumping", "Parkour", "Swimming", "Throwing"]
        RULES {
            #JSCdVNxJCSVgYAsn45K6qf: combat_substitute_no_damage
            #DyjFKvhzAx9ZtnGNyMFJsV: pursuit_advantage
            #KuWsFgg3JJDFMEfuenUmeP: environmental_traversal
        }
    }
    ^"Brawl" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Enables characters to hit their target when they swing with fist, boot,
        # or claw. Covers unarmed combat from elegant aikijutsu to dirty street fighting.
        SPECIALTIES ["Animals", "Armed Mortals", "Bar Fights", "Grappling", "Kindred", "Sporting Combat", "Unarmed Mortals", "Werewolves", "While in Protean Beast Form"]
        RULES {
            #gZhQ8Q4uYVmobEB4wHi4TK: unarmed_attack_rolls
            #ccthgjBaru9ybXtckc3gtt: grappling_maneuvers
            #hqnNCUukLh7TxSJTirTvtB: improvised_weapons
        }
    }
    ^"Craft" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Broadly encompasses artistry, creation of items from beautiful to functional,
        # arts and crafts from pottery to building and reinforcing your haven.
        # Grants one free specialty when acquired.
        SPECIALTIES ["Carpentry", "Carving", "Design", "Painting", "Sculpting", "Sewing", "Weaponsmithing"]
        RULES {
            #nyza6zQpcrddxYeVS9QZBj: creation_quality

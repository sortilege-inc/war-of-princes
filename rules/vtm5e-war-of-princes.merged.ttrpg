    ^"Blood Bond" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        # A mystical power relationship between two individual vampires, where
        # one has partaken of the other's Blood thrice; accepting Blood from a
        # vampire is an acknowledgment of their mastery.
        RULES {
            #o5NNamMx95M59w7YJSDwuf: blood_bond_three_drinks

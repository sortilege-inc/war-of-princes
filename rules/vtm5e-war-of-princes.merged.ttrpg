            #MYjU2JjYDKg6crFd9KvEGa: disarming_techniques
        }
    }
    ^"Stealth" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Allows a character to shadow a target, spy, sneak, and blend in with crowds.
        # Makes vampires superlative hunters through concealment abilities.
        SPECIALTIES ["Ambushes", "Crowds", "Disguise", "Hiding", "Shadowing", "Silent Movement", "Urban", "Wilderness"]
        RULES {
            #DpDTDQMwCKAca8gdUpE6YC: concealment_bonus
            #fJmZY88cLTNoXzM7vzzRrF: shadowing_targets
            #6F3VhCHonHkj3saw8ZHSok: crowd_blending
        }
    }
    ^"Survival" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # establish makeshift havens, notice werewolf signs. Functions also apply
        # in urban wastelands and brownfields.
        SPECIALTIES ["Desert", "Hunting", "Jungle", "Tracking", "Traps", "Shelters", "Urban Exploration", "Woodlands"]
        RULES {

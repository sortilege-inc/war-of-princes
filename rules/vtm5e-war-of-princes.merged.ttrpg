    #K3lM5nO7pQ9rS1tU3vW5x ACTOR "Coterie" DEF {
        EXTENDS #VnK8MrPxWbGhN2fQ4sT6uW ^"Entity"
        # A group of player characters working together
        # Has group-level properties and resources
        PROPERTIES {

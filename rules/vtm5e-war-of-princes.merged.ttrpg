    ^"Resolve" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 1 MAX 5
        # Mental fortitude, determination, and focus. Ability to concentrate
        # despite distractions and resist mental intrusion or manipulation.
        RULES {
            #eqywxctsKARSYUHiK3ofHc: willpower_calculation
            #ZEHgDZCjvZti7MsDVXumJb: mental_resistance
            #mjrBxYjxphvUahNhnwwhTy: concentration_maintenance

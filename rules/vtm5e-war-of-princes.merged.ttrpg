            #5u8KFt4F7RjHTdPhQwyMst: artistic_expression
        }
    }
    ^"Drive" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # speed away from ambushes, win street races, escape Second Inquisition chases.
        SPECIALTIES ["All-Terrain Vehicles", "Evasion", "Motorcycles", "Street Racing", "Stunts", "Tailing", "Trucks", "Vintage Models"]
        RULES {
            #Z6AkWM5CAbhWNRwZjxy37q: high_speed_maneuvering
            #CKBahJ5GbM2csMxdU3nziJ: chase_sequences
            #mY5NHoxrKcyhCQCWHDiLbh: vehicle_stunts
        }
    }
    ^"Firearms" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Familiarity with small arms from holdout pistols to assault rifles,
        # trigger-operated weapons like crossbows and RPGs. Includes cleaning,
        # unjamming, and rapidly reloading such weapons.
        SPECIALTIES ["Crossbows", "Gun Dealing", "Gunsmithing", "Handloading Ammunition", "Quick-Draw", "Sniper", "Trick Shooting"]
        RULES {
            #GaJQBttbAnDQqS6FLDPPWf: ranged_attack_rolls
            #VR8KVqSVucb5xEm3xYsSPz: weapon_maintenance
            #4jopXkzC9jkzV6MbkM6zgX: called_shots
        }
    }
    ^"Larceny" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Tools and techniques for picking locks, planting bugs, deactivating alarms,
        # manual forgery, hot-wiring automobiles, safecracking, and breaking and entering.
        # Also used for setting up security systems.
        SPECIALTIES ["Alarms", "Forgery", "Grand Theft Auto", "Housebreaking", "Lockpicking", "Pickpocket", "Safecracking", "Security Analysis"]
        RULES {
            #6XETzwL7JJoyUcbymueoFb: lock_picking
            #bJRbaBABc3wMhXTYFSR52t: security_bypass
            #Q9zHUUaFWM3n7vPETtLPCC: theft_techniques
        }
    }
    ^"Melee" DEF {
        APPLIES TO [^"Kindred", ^"Mortal", ^"Ghoul"]
        INTEGER MIN 0 MAX 5
        # Wielding handheld weapons such as knives, chains, baseball bats, and stakes
        # with prowess. Covers all forms of armed melee combat.
        SPECIALTIES ["Axes", "Chains", "Clubs", "Fencing", "Disarming Blows", "Garrotes", "Improvised Weapons", "Knives", "Stakes", "Swords"]
        RULES {
